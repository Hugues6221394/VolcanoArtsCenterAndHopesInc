/* ═══════════════════════════════════════════════════════════════
   VOLCANO ARTS CENTER — Design System (V2 · Volcanic Editorial)
   Logo green #00A651 · Cormorant Garamond + Syne + DM Sans + DM Mono
   ═══════════════════════════════════════════════════════════════ */

/* ── Google Fonts (V2 spec: Cormorant Garamond + Syne + DM Sans + DM Mono) ── */
@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Syne:wght@400;500;600;700;800&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&family=DM+Mono:wght@400;500&display=swap');

/* ═══════════════════════════════════════
   DESIGN TOKENS — Premium White + Forest Green
   Inspired by editorial tourism platforms
   (Golden Rwanda, Singita, Andbeyond) but
   anchored to the Volcano Arts Center logo green.
   ═══════════════════════════════════════ */
:root {
    /* ── Brand greens (logo-derived) ── */
    --green:         #00A651;
    --green-dark:    #007A3D;
    --green-deeper:  #004D26;
    --green-tint:    #E8F7EE;
    --green-mid:     #B3DFC7;

    /* ── Neutrals ── */
    --black:         #0B0B0B;
    --charcoal:      #1C1C1C;
    --smoke:         #2A2A2A;
    --ash:           #6B6B6B;
    --stone:         #C2C2BD;
    --ivory:         #F9F8F5;
    --white:         #FFFFFF;

    /* ── Earth accents (use sparingly) ── */
    --earth:         #C2621A;
    --sand:          #E8D4B0;

    /* ── Semantic ── */
    --color-success: var(--green);
    --color-warning: #B8860B;
    --color-error:   #B3261E;
    --color-info:    var(--green-dark);

    /* ── Gradients ── */
    --gradient-primary: linear-gradient(135deg, var(--green-deeper) 0%, var(--green) 55%, #2BC077 100%);
    --gradient-hero:    linear-gradient(to top, rgba(0,0,0,0.55) 0%, transparent 60%);
    --gradient-forest:  linear-gradient(135deg, #003319 0%, var(--green-deeper) 50%, var(--green-dark) 100%);

    /* ── Typography ── */
    --font-display: 'Cormorant Garamond', Georgia, serif;
    --font-ui:      'Syne', system-ui, sans-serif;
    --font-body:    'DM Sans', system-ui, sans-serif;
    --font-mono:    'DM Mono', ui-monospace, 'SF Mono', Menlo, monospace;
    --font-heading: var(--font-display);
    --font-eyebrow: var(--font-ui);

    /* ── Type scale (V2 spec) ── */
    --text-display:   clamp(3.5rem, 6.5vw, 6.5rem);
    --text-headline:  clamp(2rem, 3.5vw, 3.25rem);
    --text-title:     clamp(1.4rem, 2vw, 1.875rem);
    --text-lead:      1.2rem;
    --text-body:      1rem;
    --text-small:     0.875rem;
    --text-label:     0.75rem;

    --leading-display: 1.05;
    --leading-tight:   1.25;
    --leading-body:    1.7;
    --track-wide:      0.08em;
    --track-wider:     0.14em;

    /* ── Backwards-compat aliases (legacy templates) ── */
    --color-primary:        var(--green);
    --color-primary-dark:   var(--green-dark);
    --color-primary-deeper: var(--green-deeper);
    --color-primary-light:  #2BC077;
    --color-primary-glow:   #57D499;
    --color-primary-muted:  rgba(0, 166, 81, 0.10);
    --color-primary-soft:   var(--green-tint);
    --color-accent:         var(--earth);
    --color-accent-soft:    var(--sand);
    --color-canvas:         var(--ivory);
    --color-paper:          var(--white);
    --color-paper-elevated: var(--white);
    --color-tint:           #F2F1EC;
    --color-band:           #EFEDE6;
    --color-line:           rgba(11, 11, 11, 0.08);
    --color-line-strong:    var(--stone);
    --color-ink:            var(--black);
    --color-ink-soft:       var(--charcoal);
    --color-ink-mute:       #3A3A3A;
    --color-ink-faint:      var(--ash);
    --color-ink-ghost:      #A8A8A3;
    --color-black:          var(--ivory);
    --color-dark:           var(--white);
    --color-dark-elevated:  var(--white);
    --color-dark-surface:   #F2F1EC;
    --color-gray-900:       var(--black);
    --color-gray-800:       var(--charcoal);
    --color-gray-700:       #3A3A3A;
    --color-gray-600:       var(--ash);
    --color-gray-500:       var(--ash);
    --color-gray-400:       #A8A8A3;
    --color-gray-300:       var(--stone);
    --color-gray-200:       rgba(11, 11, 11, 0.08);
    --color-gray-100:       #F2F1EC;
    --color-white:          var(--black);
    --color-pure-white:     var(--white);

    --gradient-band:        linear-gradient(180deg, var(--ivory) 0%, #EFEDE6 100%);
    --gradient-card:        linear-gradient(180deg, var(--white) 0%, var(--white) 100%);
    --gradient-glass:       linear-gradient(135deg, rgba(255, 255, 255, 0.85) 0%, rgba(255, 255, 255, 0.65) 100%);
    --gradient-dark:        linear-gradient(180deg, var(--ivory) 0%, #EFEDE6 100%);

    /* Even-older legacy tokens (conservation, dashboards, talent etc.) */
    --color-surface:        var(--white);
    --color-surface-2:      #EFEDE6;
    --color-border:         var(--color-line);
    --color-border-strong:  var(--stone);
    --color-text:           var(--charcoal);
    --color-muted:          var(--ash);
    --color-bg:             var(--ivory);
    --color-background:     var(--ivory);
    --color-background-alt: #EFEDE6;

    --fs-hero: clamp(3rem, 6vw, 5.5rem);
    --fs-h1: clamp(2.2rem, 4vw, 3.5rem);
    --fs-h2: clamp(1.8rem, 3vw, 2.5rem);
    --fs-h3: clamp(1.3rem, 2vw, 1.75rem);
    --fs-h4: 1.25rem;
    --fs-body: 1rem;
    --fs-body-lg: 1.125rem;
    --fs-small: 0.875rem;
    --fs-caption: 0.75rem;

    --lh-tight: 1.15;
    --lh-heading: 1.3;
    --lh-body: 1.7;

    /* ── Spacing ── */
    --space-xs: 0.25rem;
    --space-sm: 0.5rem;
    --space-md: 1rem;
    --space-lg: 1.5rem;
    --space-xl: 2rem;
    --space-2xl: 3rem;
    --space-3xl: 4rem;
    --space-4xl: 6rem;
    --space-5xl: 8rem;
    --space-section: clamp(4rem, 8vw, 8rem);

    /* ── Border Radius ── */
    --radius-sm: 6px;
    --radius-md: 12px;
    --radius-lg: 20px;
    --radius-xl: 28px;
    --radius-full: 9999px;

    /* ── Shadows (V2 spec) ── */
    --shadow-sm:      0 1px 4px rgba(0, 0, 0, 0.07);
    --shadow-md:      0 4px 16px rgba(0, 0, 0, 0.09);
    --shadow-lg:      0 12px 40px rgba(0, 0, 0, 0.12);
    --shadow-xl:      0 24px 64px rgba(0, 0, 0, 0.16);
    --shadow-green:   0 8px 28px rgba(0, 166, 81, 0.28);
    --shadow-glow:    var(--shadow-green);
    --shadow-glow-lg: 0 16px 48px rgba(0, 166, 81, 0.30);
    --shadow-ring:    0 0 0 3px rgba(0, 166, 81, 0.10);

    /* ── Motion (V2 spec) ── */
    --ease-out:    cubic-bezier(0.16, 1, 0.3, 1);
    --ease-inout:  cubic-bezier(0.4, 0, 0.2, 1);
    --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
    --dur-micro:   120ms;
    --dur-fast:    250ms;
    --dur-normal:  400ms;
    --dur-slow:    700ms;
    --dur-scene:   1100ms;

    /* ── Transitions ── */
    --transition-fast: 150ms cubic-bezier(0.4, 0, 0.2, 1);
    --transition-base: 300ms cubic-bezier(0.4, 0, 0.2, 1);
    --transition-slow: 500ms cubic-bezier(0.4, 0, 0.2, 1);
    --transition-spring: 500ms cubic-bezier(0.175, 0.885, 0.32, 1.275);

    /* ── Z-index ── */
    --z-dropdown: 100;
    --z-sticky: 200;
    --z-fixed: 300;
    --z-overlay: 400;
    --z-modal: 500;
    --z-toast: 600;

    /* ── Layout ── */
    --container-max: 1280px;
    --container-narrow: 900px;
    --container-wide: 1440px;
    --nav-height: 80px;
}

/* Light is now the default. data-theme="dark" is the optional alternate. */
html[data-theme="dark"] {
    --color-canvas: #0A1410;
    --color-paper: #11201A;
    --color-paper-elevated: #16291F;
    --color-tint: #1A2F25;
    --color-band: #14241D;
    --color-line: rgba(255, 255, 255, 0.08);
    --color-line-strong: rgba(255, 255, 255, 0.16);

    --color-ink: #F2F5F1;
    --color-ink-soft: #DDE5DD;
    --color-ink-mute: #B5C4B9;
    --color-ink-faint: #8AA193;
    --color-ink-ghost: #5C7367;

    --color-primary-soft: rgba(0, 162, 89, 0.10);

    --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.30), 0 2px 6px rgba(0, 0, 0, 0.30);
    --shadow-md: 0 4px 14px rgba(0, 0, 0, 0.35);
    --shadow-lg: 0 12px 32px rgba(0, 0, 0, 0.40);
    --shadow-xl: 0 24px 56px rgba(0, 0, 0, 0.50);
}


/* ═══════════════════════════════════════
   RESET & BASE
   ═══════════════════════════════════════ */
*,
*::before,
*::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
}

body {
    font-family: var(--font-body);
    font-size: var(--text-body);
    line-height: var(--leading-body);
    color: var(--charcoal);
    background-color: var(--ivory);
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
}

h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-display);
    color: var(--black);
    line-height: var(--leading-tight);
    font-weight: 500;
}

h1 { font-size: var(--text-headline); font-weight: 600; line-height: var(--leading-display); }
h2 { font-size: var(--text-headline); font-weight: 500; }
h3 { font-size: var(--text-title);    font-weight: 500; }
h4 { font-size: 1.125rem;              font-weight: 600; font-family: var(--font-ui); letter-spacing: 0.04em; text-transform: uppercase; }

p { color: var(--charcoal); }

/* DM Mono for prices, KPIs, IDs, dates */
.mono, .num, [data-mono] { font-family: var(--font-mono); font-feature-settings: "tnum"; }

/* Cormorant deserves room — never below 18px per V2 spec */
.display-text { font-family: var(--font-display); font-size: var(--text-display); font-weight: 700; line-height: var(--leading-display); }

img {
    max-width: 100%;
    height: auto;
    display: block;
}

a {
    color: var(--green-dark);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-out);
}

a:hover {
    color: var(--green);
}

::selection {
    background: var(--green);
    color: var(--white);
}

/* Editorial eyebrow text — section labels, taglines (Syne uppercase, V2) */
.eyebrow,
.section-label,
.section__eyebrow {
    font-family: var(--font-ui);
    font-size: 0.6875rem;     /* 11px */
    font-weight: 600;
    letter-spacing: var(--track-wider);
    text-transform: uppercase;
    color: var(--green-dark);
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    line-height: 1;
}
.eyebrow::before,
.section-label::before {
    content: '';
    width: 28px;
    height: 1px;
    background: currentColor;
    opacity: 0.6;
}


/* ═══════════════════════════════════════
   LAYOUT UTILITIES
   ═══════════════════════════════════════ */
.container {
    width: 100%;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--space-xl);
}

.container--narrow {
    max-width: var(--container-narrow);
}

.container--wide {
    max-width: var(--container-wide);
}

.section {
    padding: var(--space-section) 0;
}

.section--dark {
    background: var(--color-dark);
}

.section--elevated {
    background: var(--color-dark-elevated);
}

.flex {
    display: flex;
}

.flex-center {
    display: flex;
    align-items: center;
    justify-content: center;
}

.grid {
    display: grid;
    gap: var(--space-xl);
}

.grid-2 {
    grid-template-columns: repeat(2, 1fr);
}

.grid-3 {
    grid-template-columns: repeat(3, 1fr);
}

.grid-4 {
    grid-template-columns: repeat(4, 1fr);
}

@media (max-width: 1024px) {
    .grid-4 {
        grid-template-columns: repeat(2, 1fr);
    }

    .grid-3 {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (max-width: 640px) {

    .grid-4,
    .grid-3,
    .grid-2 {
        grid-template-columns: 1fr;
    }

    .container {
        padding: 0 var(--space-md);
    }
}


/* ═══════════════════════════════════════
   TYPOGRAPHY
   ═══════════════════════════════════════ */
h1,
h2,
h3,
h4,
h5,
h6 {
    font-family: var(--font-heading);
    color: var(--color-white);
    line-height: var(--lh-heading);
    font-weight: 600;
}

h1 {
    font-size: var(--fs-h1);
}

h2 {
    font-size: var(--fs-h2);
}

h3 {
    font-size: var(--fs-h3);
}

h4 {
    font-size: var(--fs-h4);
}

.text-display {
    font-family: var(--font-display);
    font-size: var(--fs-hero);
    font-weight: 700;
    line-height: var(--lh-tight);
    letter-spacing: -0.02em;
}

.text-display em,
.text-display i {
    font-style: italic;
    color: var(--color-primary-light);
}

.text-accent {
    color: var(--color-primary-light);
}

.text-muted {
    color: var(--color-gray-500);
}

.text-center {
    text-align: center;
}

.section-label {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-heading);
    font-size: var(--fs-small);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-primary-light);
    margin-bottom: var(--space-md);
}

.section-label::before {
    content: '';
    display: inline-block;
    width: 24px;
    height: 2px;
    background: var(--color-primary);
}

.section-subtitle {
    font-size: var(--fs-body-lg);
    color: var(--color-gray-400);
    max-width: 640px;
    line-height: var(--lh-body);
}

.section-subtitle.centered {
    margin: 0 auto;
}


/* ═══════════════════════════════════════
   NAVIGATION
   ═══════════════════════════════════════ */
.nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--nav-height);
    z-index: var(--z-fixed);
    transition: background var(--transition-base), box-shadow var(--transition-base);
}

.nav.scrolled {
    background: rgba(10, 10, 10, 0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.05);
}

.nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: 0 var(--space-xl);
}

.nav__logo {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-white);
    text-decoration: none;
    letter-spacing: -0.01em;
}

.nav__logo img {
    height: 42px;
    width: auto;
}

.nav__logo-image {
    height: 44px;
    width: auto;
    border-radius: 4px;
    object-fit: contain;
}

.nav__logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
}

.nav__logo-text span:first-child {
    font-weight: 700;
    color: var(--color-white);
}

.nav__logo-text span:last-child {
    font-size: 0.7rem;
    color: var(--color-primary-glow);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
}

.nav__links {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    list-style: none;
}

.nav__links a {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-gray-300);
    text-decoration: none;
    padding: var(--space-sm) 0;
    position: relative;
    transition: color var(--transition-fast);
}

.nav__links a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--color-primary);
    transition: width var(--transition-base);
}

.nav__links a:hover,
.nav__links a.active {
    color: var(--color-white);
}

.nav__links a:hover::after,
.nav__links a.active::after {
    width: 100%;
}

.nav__cta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
}

.nav__client-utility {
    display: inline-flex;
    align-items: center;
    gap: .55rem;
    padding: .35rem;
    border-radius: var(--radius-full);
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.03);
}

.nav__client-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: .72rem 1.15rem;
    border-radius: var(--radius-full);
    border: 1px solid transparent;
    background: transparent;
    color: var(--color-gray-200);
    font-family: var(--font-heading);
    font-size: .86rem;
    font-weight: 600;
    text-decoration: none;
    transition: all var(--transition-fast);
}

.nav__client-pill:hover {
    color: var(--color-white);
    border-color: rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.05);
}

.nav__client-pill--strong {
    background: linear-gradient(135deg, rgba(0, 162, 89, 0.95), rgba(35, 201, 120, 0.88));
    color: var(--color-white);
    box-shadow: 0 10px 26px rgba(0, 162, 89, 0.24);
}

.nav__client-pill--strong:hover {
    border-color: transparent;
    background: linear-gradient(135deg, rgba(35, 201, 120, 0.98), rgba(0, 162, 89, 0.92));
}

.nav__client-pill--active {
    color: var(--color-white);
    border-color: rgba(0, 162, 89, 0.34);
    background: rgba(0, 162, 89, 0.16);
}

.nav__client-pill--button {
    cursor: pointer;
}

.nav__client-pill--button:hover {
    background: rgba(255, 255, 255, 0.06);
}

.theme-toggle {
    display: inline-flex;
    align-items: center;
    gap: .35rem;
    border-radius: var(--radius-full);
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.04);
    color: var(--color-gray-200);
    font-family: var(--font-heading);
    font-size: .78rem;
    padding: .45rem .8rem;
    cursor: pointer;
    transition: all var(--transition-fast);
}

.theme-toggle:hover {
    border-color: rgba(0, 162, 89, 0.42);
    color: var(--color-primary-light);
}

/* Mobile Menu Toggle */
.nav__toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-sm);
}

.nav__toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-white);
    transition: var(--transition-base);
}

@media (max-width: 1024px) {
    .nav__toggle {
        display: flex;
    }

    .nav__links {
        display: none;
        position: absolute;
        top: var(--nav-height);
        left: 0;
        right: 0;
        flex-direction: column;
        background: rgba(10, 10, 10, 0.98);
        backdrop-filter: blur(20px);
        padding: var(--space-xl);
        gap: var(--space-md);
        border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    .nav__links.open {
        display: flex;
    }

    .nav__cta {
        display: none;
    }
}


/* ═══════════════════════════════════════
   BUTTONS
   ═══════════════════════════════════════ */
.btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0.75rem 1.75rem;
    border-radius: var(--radius-full);
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: all var(--transition-base);
    position: relative;
    overflow: hidden;
}

.btn::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    opacity: 0;
    transition: opacity var(--transition-fast);
}

.btn:hover::before {
    opacity: 1;
}

.btn--primary {
    background: var(--color-primary);
    color: var(--color-pure-white);
    box-shadow: 0 4px 15px rgba(0, 162, 89, 0.34);
}

.btn--primary::before {
    background: linear-gradient(135deg, var(--color-primary-light), var(--color-primary));
}

.btn--primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0, 162, 89, 0.45);
    color: var(--color-pure-white);
}

.btn--outline {
    background: transparent;
    color: var(--color-white);
    border: 1.5px solid rgba(255, 255, 255, 0.2);
}

.btn--outline::before {
    background: rgba(255, 255, 255, 0.05);
}

.btn--outline:hover {
    border-color: var(--color-primary);
    color: var(--color-primary-light);
    transform: translateY(-2px);
}

.btn--ghost {
    background: transparent;
    color: var(--color-primary-light);
    padding: 0.5rem 1rem;
}

.btn--ghost:hover {
    background: var(--color-primary-muted);
    color: var(--color-primary-glow);
}

.btn--lg {
    padding: 1rem 2.25rem;
    font-size: 1rem;
}

.btn--sm {
    padding: 0.5rem 1.25rem;
    font-size: 0.8rem;
}

.btn--icon {
    width: 40px;
    height: 40px;
    padding: 0;
    border-radius: var(--radius-full);
}


/* ═══════════════════════════════════════
   HERO SECTION
   ═══════════════════════════════════════ */
.hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
}

.hero__bg {
    position: absolute;
    inset: 0;
    z-index: -2;
}

.hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.hero__overlay {
    position: absolute;
    inset: 0;
    background: var(--gradient-hero);
    z-index: -1;
}

.hero__content {
    max-width: 720px;
    padding-top: var(--nav-height);
}

.hero__tagline {
    font-family: var(--font-heading);
    font-size: var(--fs-small);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-primary-light);
    margin-bottom: var(--space-lg);
    display: flex;
    align-items: center;
    gap: var(--space-md);
}

.hero__tagline::before {
    content: '';
    width: 40px;
    height: 2px;
    background: var(--color-primary);
}

.hero__title {
    font-family: var(--font-display);
    font-size: var(--fs-hero);
    font-weight: 700;
    color: var(--color-white);
    line-height: var(--lh-tight);
    margin-bottom: var(--space-xl);
    letter-spacing: -0.02em;
}

.hero__title .highlight {
    color: var(--color-primary-light);
    font-style: italic;
}

.hero__desc {
    font-size: var(--fs-body-lg);
    color: var(--color-gray-300);
    line-height: var(--lh-body);
    margin-bottom: var(--space-2xl);
    max-width: 560px;
}

.hero__actions {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
}

.hero__stats {
    display: flex;
    gap: var(--space-3xl);
    margin-top: var(--space-4xl);
    padding-top: var(--space-2xl);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
}

.hero__stat {
    text-align: left;
}

.hero__stat-value {
    font-family: var(--font-heading);
    font-size: var(--fs-h2);
    font-weight: 700;
    color: var(--color-white);
}

.hero__stat-value .accent {
    color: var(--color-primary-light);
}

.hero__stat-label {
    font-size: var(--fs-small);
    color: var(--color-gray-500);
    margin-top: var(--space-xs);
}

/* Animated decorative element */
.hero__decor {
    position: absolute;
    right: -100px;
    top: 50%;
    transform: translateY(-50%);
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(0, 162, 89, 0.16) 0%, transparent 70%);
    filter: blur(60px);
    animation: pulse-glow 6s ease-in-out infinite;
}

@keyframes pulse-glow {

    0%,
    100% {
        opacity: 0.5;
        transform: translateY(-50%) scale(1);
    }

    50% {
        opacity: 0.8;
        transform: translateY(-50%) scale(1.1);
    }
}


/* ═══════════════════════════════════════
   CARDS
   ═══════════════════════════════════════ */
.card {
    background: var(--gradient-card);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all var(--transition-base);
    position: relative;
}

.card:hover {
    transform: translateY(-4px);
    border-color: rgba(0, 162, 89, 0.35);
    box-shadow: var(--shadow-glow);
}

.card__image {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4/3;
}

.card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
}

.card:hover .card__image img {
    transform: scale(1.05);
}

.card__badge {
    position: absolute;
    top: var(--space-md);
    left: var(--space-md);
    background: var(--color-primary);
    color: var(--color-pure-white);
    font-family: var(--font-heading);
    font-size: var(--fs-caption);
    font-weight: 600;
    padding: 4px 12px;
    border-radius: var(--radius-full);
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.card__body {
    padding: var(--space-lg);
}

.card__category {
    font-family: var(--font-heading);
    font-size: var(--fs-caption);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primary-light);
    margin-bottom: var(--space-sm);
}

.card__title {
    font-size: var(--fs-h4);
    margin-bottom: var(--space-sm);
    color: var(--color-white);
}

.card__title a {
    color: inherit;
    text-decoration: none;
}

.card__title a:hover {
    color: var(--color-primary-light);
}

.card__text {
    font-size: var(--fs-small);
    color: var(--color-gray-400);
    line-height: var(--lh-body);
    margin-bottom: var(--space-md);
}

.card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-md);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    font-size: var(--fs-small);
}

.media-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    grid-auto-rows: minmax(170px, auto);
    gap: 1rem;
}

.media-card {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.10);
    min-height: 210px;
    box-shadow: var(--shadow-md);
}

.media-card--feature {
    grid-row: span 2;
    min-height: 440px;
}

.media-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow), filter var(--transition-base);
    filter: saturate(1.02) contrast(1.03);
}

.media-card:hover img {
    transform: scale(1.06);
    filter: saturate(1.1) contrast(1.05);
}

.media-card__caption {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: .9rem 1rem;
    background: linear-gradient(180deg, rgba(2, 9, 7, 0) 0%, rgba(2, 9, 7, 0.86) 60%, rgba(2, 9, 7, 0.95) 100%);
}

.media-card__caption h3 {
    font-size: 1rem;
    margin-bottom: .3rem;
}

.media-card__caption p {
    font-size: .83rem;
    color: #d2e7dd;
}

.video-embed-card {
    margin-top: 1rem;
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.10);
    background: linear-gradient(145deg, rgba(18, 21, 20, 0.95), rgba(11, 13, 12, 0.98));
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 1rem;
    padding: 1rem;
}

.video-embed-card__content p {
    color: var(--color-gray-400);
    margin-top: .45rem;
}

.video-embed-card__frame {
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    min-height: 260px;
}

.video-embed-card__frame iframe {
    width: 100%;
    height: 100%;
    min-height: 260px;
    border: 0;
}

.video-grid {
    display: grid;
    gap: .7rem;
    grid-template-columns: 1fr 1fr;
    height: 100%;
}

.video-mini {
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(0, 0, 0, 0.25);
}

.video-mini iframe {
    width: 100%;
    height: 210px;
    border: 0;
}

.video-mini span {
    display: block;
    padding: .4rem .55rem;
    font-size: .78rem;
    color: var(--color-gray-300);
}

.image-strip {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: .8rem;
}

.image-strip img {
    border-radius: var(--radius-md);
    width: 100%;
    height: 180px;
    object-fit: cover;
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: transform var(--transition-base), box-shadow var(--transition-base);
}

.image-strip img:hover {
    transform: translateY(-5px) scale(1.02);
    box-shadow: var(--shadow-md);
}

.card__price {
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-white);
    font-size: var(--fs-body-lg);
}

.card__price .old-price {
    text-decoration: line-through;
    color: var(--color-gray-600);
    font-weight: 400;
    font-size: var(--fs-small);
    margin-right: var(--space-sm);
}

/* Glass variant */
.card--glass {
    background: var(--gradient-glass);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.1);
}


/* ═══════════════════════════════════════
   DEPARTMENT / FEATURE CARDS
   ═══════════════════════════════════════ */
.dept-card {
    padding: var(--space-2xl);
    background: var(--gradient-card);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-lg);
    transition: all var(--transition-base);
    position: relative;
    overflow: hidden;
}

.dept-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--gradient-primary);
    opacity: 0;
    transition: opacity var(--transition-base);
}

.dept-card:hover {
    transform: translateY(-4px);
    border-color: rgba(0, 162, 89, 0.24);
    box-shadow: var(--shadow-md);
}

.dept-card:hover::before {
    opacity: 1;
}

.dept-card__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: var(--radius-md);
    background: var(--color-primary-muted);
    color: var(--color-primary-light);
    font-size: 1.5rem;
    margin-bottom: var(--space-lg);
}

.dept-card__title {
    font-size: var(--fs-h4);
    margin-bottom: var(--space-sm);
}

.dept-card__text {
    font-size: var(--fs-small);
    color: var(--color-gray-400);
    line-height: var(--lh-body);
    margin-bottom: var(--space-lg);
}

.dept-card__link {
    font-family: var(--font-heading);
    font-size: var(--fs-small);
    font-weight: 600;
    color: var(--color-primary-light);
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    transition: gap var(--transition-base);
}

.dept-card__link:hover {
    gap: var(--space-md);
}


/* ═══════════════════════════════════════
   TESTIMONIALS
   ═══════════════════════════════════════ */
.testimonial {
    padding: var(--space-2xl);
    background: var(--gradient-card);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-lg);
    position: relative;
}

.testimonial__quote {
    font-family: var(--font-display);
    font-size: var(--fs-body-lg);
    font-style: italic;
    color: var(--color-gray-200);
    line-height: var(--lh-body);
    margin-bottom: var(--space-lg);
}

.testimonial__quote::before {
    content: '"';
    font-family: var(--font-display);
    font-size: 4rem;
    color: var(--color-primary);
    opacity: 0.3;
    position: absolute;
    top: var(--space-md);
    left: var(--space-lg);
    line-height: 1;
}

.testimonial__author {
    display: flex;
    align-items: center;
    gap: var(--space-md);
}

.testimonial__avatar {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-full);
    object-fit: cover;
    border: 2px solid var(--color-primary);
}

.testimonial__name {
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--color-white);
    font-size: var(--fs-small);
}

.testimonial__origin {
    font-size: var(--fs-caption);
    color: var(--color-gray-500);
}

.testimonial__stars {
    color: var(--color-warning);
    font-size: var(--fs-small);
    margin-bottom: var(--space-md);
}


/* ═══════════════════════════════════════
   IMPACT NUMBERS
   ═══════════════════════════════════════ */
.impact-bar {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-xl);
    padding: var(--space-3xl) 0;
}

.impact-item {
    text-align: center;
    padding: var(--space-xl);
    border-radius: var(--radius-lg);
    background: var(--gradient-glass);
    border: 1px solid rgba(255, 255, 255, 0.06);
}

.impact-item__value {
    font-family: var(--font-heading);
    font-size: var(--fs-h1);
    font-weight: 800;
    color: var(--color-primary-light);
    margin-bottom: var(--space-sm);
}

.impact-item__label {
    font-size: var(--fs-small);
    color: var(--color-gray-400);
    text-transform: uppercase;
    letter-spacing: 0.08em;
}

@media (max-width: 768px) {
    .impact-bar {
        grid-template-columns: repeat(2, 1fr);
    }
}


/* ═══════════════════════════════════════
   FOOTER
   ═══════════════════════════════════════ */
.footer {
    background: var(--color-dark);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding: var(--space-4xl) 0 var(--space-xl);
}

.footer__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--space-3xl);
    margin-bottom: var(--space-3xl);
}

.footer__brand p {
    color: var(--color-gray-500);
    font-size: var(--fs-small);
    margin-top: var(--space-md);
    max-width: 320px;
    line-height: var(--lh-body);
}

.footer__social {
    display: flex;
    gap: var(--space-md);
    margin-top: var(--space-lg);
}

.footer__social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-full);
    background: rgba(255, 255, 255, 0.05);
    color: var(--color-gray-400);
    transition: all var(--transition-base);
}

.footer__social a:hover {
    background: var(--color-primary);
    color: var(--color-pure-white);
    transform: translateY(-2px);
}

.footer__heading {
    font-family: var(--font-heading);
    font-size: var(--fs-small);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-white);
    margin-bottom: var(--space-lg);
}

.footer__links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
}

.footer__links a {
    font-size: var(--fs-small);
    color: var(--color-gray-500);
    transition: color var(--transition-fast);
}

.footer__links a:hover {
    color: var(--color-primary-light);
}

.footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-xl);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    font-size: var(--fs-caption);
    color: var(--color-gray-600);
}

@media (max-width: 768px) {
    .footer__grid {
        grid-template-columns: 1fr 1fr;
        gap: var(--space-2xl);
    }

    .footer__bottom {
        flex-direction: column;
        gap: var(--space-sm);
    }
}

@media (max-width: 480px) {
    .footer__grid {
        grid-template-columns: 1fr;
    }
}


/* ═══════════════════════════════════════
   CTA SECTION
   ═══════════════════════════════════════ */
.cta-section {
    position: relative;
    padding: var(--space-5xl) 0;
    text-align: center;
    overflow: hidden;
}

.cta-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, rgba(26, 107, 60, 0.15) 0%, transparent 60%);
    pointer-events: none;
}

.cta-section h2 {
    margin-bottom: var(--space-md);
}

.cta-section p {
    max-width: 560px;
    margin: 0 auto var(--space-2xl);
    color: var(--color-gray-400);
}

.cta-section .btn-group {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    flex-wrap: wrap;
}


/* ═══════════════════════════════════════
   ANIMATIONS
   ═══════════════════════════════════════ */
@keyframes fade-in-up {
    from {
        opacity: 0;
        transform: translateY(30px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes fade-in {
    from {
        opacity: 0;
    }

    to {
        opacity: 1;
    }
}

@keyframes slide-in-left {
    from {
        opacity: 0;
        transform: translateX(-40px);
    }

    to {
        opacity: 1;
        transform: translateX(0);
    }
}

.animate-on-scroll {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease, transform 0.8s ease;
}

.animate-on-scroll.visible {
    opacity: 1;
    transform: translateY(0);
}

.stagger-1 {
    transition-delay: 0.1s;
}

.stagger-2 {
    transition-delay: 0.2s;
}

.stagger-3 {
    transition-delay: 0.3s;
}

.stagger-4 {
    transition-delay: 0.4s;
}


/* ═══════════════════════════════════════
   FORMS
   ═══════════════════════════════════════ */
.form-group {
    margin-bottom: var(--space-lg);
}

.form-label {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--fs-small);
    font-weight: 600;
    color: var(--color-gray-300);
    margin-bottom: var(--space-sm);
}

.form-input,
.form-textarea,
.form-select {
    width: 100%;
    padding: 0.75rem 1rem;
    font-family: var(--font-body);
    font-size: var(--fs-body);
    color: var(--color-white);
    background: var(--color-dark-surface);
    border: 1.5px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-md);
    outline: none;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
}

.form-input:focus,
.form-textarea:focus,
.form-select:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px var(--color-primary-muted);
}

.form-textarea {
    min-height: 120px;
    resize: vertical;
}

.form-input::placeholder,
.form-textarea::placeholder {
    color: var(--color-gray-600);
}


/* ═══════════════════════════════════════
   PAGE HEADER (inner pages)
   ═══════════════════════════════════════ */
.page-header {
    position: relative;
    padding: calc(var(--nav-height) + var(--space-4xl)) 0 var(--space-3xl);
    background: var(--color-dark);
    overflow: hidden;
}

.page-header::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-primary), transparent);
}

.page-header__decor {
    position: absolute;
    right: -200px;
    top: 0;
    width: 600px;
    height: 100%;
    background: radial-gradient(circle, rgba(26, 107, 60, 0.08) 0%, transparent 60%);
    pointer-events: none;
}

.breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--fs-small);
    color: var(--color-gray-500);
    margin-bottom: var(--space-lg);
}

.breadcrumb a {
    color: var(--color-gray-500);
}

.breadcrumb a:hover {
    color: var(--color-primary-light);
}

.breadcrumb__separator {
    color: var(--color-gray-700);
}


/* ═══════════════════════════════════════
   LOADING / SKELETON
   ═══════════════════════════════════════ */
.skeleton {
    background: linear-gradient(90deg, var(--color-dark-surface) 25%, var(--color-gray-800) 50%, var(--color-dark-surface) 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
    border-radius: var(--radius-sm);
}

@keyframes shimmer {
    from {
        background-position: 200% 0;
    }

    to {
        background-position: -200% 0;
    }
}

/* ═══════════════════════════════════════
   PREMIUM RWANDA UI OVERHAUL
   ═══════════════════════════════════════ */

body::before {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    background-image:
        radial-gradient(circle at 12% 18%, rgba(0, 162, 89, 0.10) 0%, transparent 32%),
        radial-gradient(circle at 88% 12%, rgba(241, 196, 15, 0.08) 0%, transparent 28%),
        radial-gradient(circle at 50% 92%, rgba(0, 138, 255, 0.07) 0%, transparent 30%);
    z-index: -1;
}

.text-kigali-luxe {
    font-family: var(--font-display);
    letter-spacing: -0.01em;
}

.hero {
    isolation: isolate;
}

.hero__bg img {
    filter: saturate(1.02) contrast(1.05) brightness(0.80);
}

.hero__overlay {
    background:
        linear-gradient(115deg, rgba(3, 8, 7, 0.90) 0%, rgba(3, 8, 7, 0.70) 38%, rgba(0, 80, 53, 0.48) 62%, rgba(2, 8, 7, 0.92) 100%),
        linear-gradient(180deg, rgba(5, 5, 5, 0.20) 0%, rgba(5, 5, 5, 0.80) 100%);
}

.hero::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 120px;
    background: linear-gradient(180deg, rgba(5, 5, 5, 0) 0%, rgba(5, 5, 5, 0.96) 100%);
    pointer-events: none;
}

.hero__title {
    text-shadow: 0 10px 40px rgba(0, 0, 0, 0.45);
}

.hero__title .highlight {
    background: linear-gradient(90deg, #7df0b9 0%, #f3dd62 52%, #89d6ff 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
}

.hero__stats {
    background: rgba(8, 14, 12, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-xl);
    padding: var(--space-xl) var(--space-2xl);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    box-shadow: var(--shadow-lg);
}

.hero__stat-value {
    background: linear-gradient(140deg, #ffffff 10%, #9effcf 55%, #fee88d 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
}

.section-label {
    position: relative;
}

.section-label::after {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: var(--radius-full);
    background: var(--color-primary-glow);
    box-shadow: 0 0 14px rgba(87, 212, 153, 0.9);
}

.dept-card,
.card,
.impact-item {
    background: linear-gradient(155deg, rgba(26, 29, 27, 0.94) 0%, rgba(17, 19, 18, 0.98) 100%);
    border: 1px solid rgba(255, 255, 255, 0.10);
    box-shadow: 0 16px 36px rgba(0, 0, 0, 0.32);
}

.dept-card:hover,
.card:hover,
.impact-item:hover {
    transform: translateY(-6px);
    border-color: rgba(126, 240, 185, 0.42);
    box-shadow: 0 22px 46px rgba(0, 0, 0, 0.36), 0 0 0 1px rgba(126, 240, 185, 0.16) inset;
}

.impact-item {
    position: relative;
    overflow: hidden;
}

.impact-item::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(110deg, transparent 30%, rgba(255, 255, 255, 0.06) 48%, transparent 65%);
    transform: translateX(-120%);
    animation: sweep 4.8s ease-in-out infinite;
}

@keyframes sweep {
    0% {
        transform: translateX(-120%);
    }

    62% {
        transform: translateX(130%);
    }

    100% {
        transform: translateX(130%);
    }
}

.page-header {
    background:
        radial-gradient(ellipse at right top, rgba(125, 240, 185, 0.08), transparent 50%),
        radial-gradient(ellipse at left top, rgba(243, 221, 98, 0.07), transparent 45%),
        var(--color-dark);
}

.nav.scrolled {
    background: rgba(8, 10, 10, 0.80);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.30);
}

.btn--primary {
    background: linear-gradient(135deg, #00a259 0%, #15b96f 52%, #1cc37a 100%);
}

.btn--primary:hover {
    box-shadow: 0 10px 28px rgba(0, 162, 89, 0.42), 0 0 0 1px rgba(147, 255, 206, 0.22) inset;
}

.btn--outline {
    border-color: rgba(137, 214, 255, 0.28);
}

.btn--outline:hover {
    background: rgba(0, 162, 89, 0.12);
}

table {
    border-collapse: separate;
    border-spacing: 0;
    overflow: hidden;
    border-radius: var(--radius-lg);
    background: rgba(11, 14, 13, 0.75);
    border: 1px solid rgba(255, 255, 255, 0.08);
}

th {
    text-align: left;
    font-family: var(--font-heading);
    font-size: var(--fs-caption);
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--color-gray-300);
    background: rgba(255, 255, 255, 0.04);
    padding: .8rem;
}

td {
    padding: .75rem .8rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
}

tr:hover td {
    background: rgba(0, 162, 89, 0.06);
}

.kpi-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
}

.kpi-card {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg);
    padding: 1.15rem 1.15rem;
    border: 1px solid rgba(255, 255, 255, 0.10);
    background: linear-gradient(145deg, rgba(18, 21, 20, 0.95), rgba(11, 13, 12, 0.98));
    box-shadow: var(--shadow-md);
}

.kpi-card::before {
    content: '';
    position: absolute;
    inset: auto -30% -52% auto;
    width: 180px;
    height: 180px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(125, 240, 185, 0.28) 0%, rgba(125, 240, 185, 0) 65%);
}

.kpi-card__label {
    display: inline-block;
    color: var(--color-gray-400);
    font-size: var(--fs-caption);
    text-transform: uppercase;
    letter-spacing: .10em;
    margin-bottom: .3rem;
}

.kpi-card__value {
    font-family: var(--font-heading);
    font-size: clamp(1.6rem, 2.4vw, 2.1rem);
    color: var(--color-white);
    font-weight: 700;
}

.kpi-card__trend {
    margin-top: .45rem;
    font-size: var(--fs-caption);
    color: #94ffca;
}

.admin-shell {
    display: grid;
    gap: 1.1rem;
}

.admin-panel {
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: var(--radius-lg);
    background: linear-gradient(150deg, rgba(18, 21, 20, 0.95), rgba(11, 13, 12, 0.98));
    padding: 1rem;
}

.admin-panel h2,
.admin-panel h3 {
    margin-bottom: .8rem;
}

.dashboard-shell {
    display: grid;
    gap: 1rem;
}

.dashboard-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .8rem;
    flex-wrap: wrap;
    border: 1px solid rgba(255, 255, 255, .1);
    border-radius: var(--radius-lg);
    background: linear-gradient(150deg, rgba(18, 21, 20, 0.95), rgba(11, 13, 12, 0.98));
    padding: .9rem 1rem;
}

.dashboard-title {
    display: grid;
    gap: .2rem;
}

.dashboard-title h1 {
    margin: 0;
    font-size: clamp(1.45rem, 2.4vw, 2rem);
}

.dashboard-title p {
    color: var(--color-gray-400);
    margin: 0;
    font-size: .9rem;
}

.dashboard-actions {
    display: flex;
    flex-wrap: wrap;
    gap: .5rem;
}

.dashboard-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1.1fr .9fr;
}

.dashboard-card {
    border: 1px solid rgba(255, 255, 255, .1);
    border-radius: var(--radius-lg);
    background: linear-gradient(150deg, rgba(18, 21, 20, 0.95), rgba(11, 13, 12, 0.98));
    padding: 1rem;
}

.dashboard-card h3 {
    margin-bottom: .7rem;
}

.list-rows {
    display: grid;
    gap: .55rem;
}

.list-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .75rem;
    border: 1px solid rgba(255, 255, 255, .08);
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, .02);
    padding: .6rem .7rem;
}

.list-row__title {
    font-weight: 600;
    color: var(--color-white);
}

.list-row__meta {
    font-size: .8rem;
    color: var(--color-gray-400);
}

.chip {
    display: inline-flex;
    align-items: center;
    border-radius: var(--radius-full);
    padding: .32rem .7rem;
    font-size: var(--fs-caption);
    letter-spacing: .08em;
    text-transform: uppercase;
    font-weight: 600;
    border: 1px solid rgba(255, 255, 255, 0.16);
    color: var(--color-gray-200);
    background: rgba(255, 255, 255, 0.04);
}

.chip--success {
    color: #a6ffd3;
    border-color: rgba(50, 235, 148, 0.45);
    background: rgba(23, 105, 70, 0.30);
}

.chip--warning {
    color: #fff1b0;
    border-color: rgba(249, 168, 37, 0.48);
    background: rgba(95, 69, 16, 0.30);
}

.chip--danger {
    color: #ffc4c4;
    border-color: rgba(255, 105, 105, 0.48);
    background: rgba(123, 35, 35, 0.28);
}

@media (max-width: 1024px) {
    .media-grid {
        grid-template-columns: 1fr 1fr;
    }

    .media-card--feature {
        grid-column: span 2;
    }

    .video-embed-card {
        grid-template-columns: 1fr;
    }

    .image-strip {
        grid-template-columns: repeat(2, 1fr);
    }

    .video-grid {
        grid-template-columns: 1fr;
    }

    .kpi-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .dashboard-grid {
        grid-template-columns: 1fr;
    }
}

@media (max-width: 640px) {
    .media-grid {
        grid-template-columns: 1fr;
    }

    .media-card--feature {
        grid-column: auto;
        min-height: 300px;
    }

    .image-strip {
        grid-template-columns: 1fr;
    }

    .kpi-grid {
        grid-template-columns: 1fr;
    }
}

@media (prefers-reduced-motion: reduce) {

    .impact-item::before,
    .hero__decor {
        animation: none !important;
    }
}

html[data-theme="light"] body::before {
    background-image:
        radial-gradient(circle at 12% 18%, rgba(0, 162, 89, 0.10) 0%, transparent 32%),
        radial-gradient(circle at 88% 12%, rgba(3, 117, 201, 0.08) 0%, transparent 28%),
        radial-gradient(circle at 50% 92%, rgba(241, 196, 15, 0.09) 0%, transparent 30%);
}

html[data-theme="light"] .nav.scrolled {
    background: rgba(255, 255, 255, 0.87);
    box-shadow: 0 10px 26px rgba(15, 56, 38, 0.12);
}

html[data-theme="light"] .hero__overlay {
    background:
        linear-gradient(115deg, rgba(255, 255, 255, 0.90) 0%, rgba(255, 255, 255, 0.67) 38%, rgba(0, 162, 89, 0.28) 62%, rgba(255, 255, 255, 0.84) 100%),
        linear-gradient(180deg, rgba(255, 255, 255, 0.18) 0%, rgba(255, 255, 255, 0.76) 100%);
}

html[data-theme="light"] .hero__title {
    text-shadow: none;
}

html[data-theme="light"] .hero__title .highlight {
    background: linear-gradient(90deg, #00884c 0%, #00a259 52%, #0b73d0 100%);
    -webkit-background-clip: text;
    background-clip: text;
}

html[data-theme="light"] .hero__stats,
html[data-theme="light"] .video-embed-card,
html[data-theme="light"] .card,
html[data-theme="light"] .dept-card,
html[data-theme="light"] .impact-item,
html[data-theme="light"] .kpi-card,
html[data-theme="light"] .admin-panel,
html[data-theme="light"] .dashboard-card,
html[data-theme="light"] .dashboard-topbar {
    background: linear-gradient(145deg, rgba(255, 255, 255, 0.96), rgba(241, 248, 244, 0.95));
    border-color: rgba(0, 92, 49, 0.14);
    box-shadow: 0 10px 24px rgba(13, 64, 40, 0.10);
}

html[data-theme="light"] .media-card__caption {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, rgba(15, 48, 34, 0.62) 60%, rgba(15, 48, 34, 0.82) 100%);
}

html[data-theme="light"] .video-mini span {
    color: #f0fffa;
}

html[data-theme="light"] table {
    background: #ffffff;
    border-color: rgba(19, 82, 52, 0.12);
}

html[data-theme="light"] th {
    background: rgba(0, 162, 89, 0.08);
}

html[data-theme="light"] tr:hover td {
    background: rgba(0, 162, 89, 0.08);
}


/* ═══════════════════════════════════════════════════════════════
   ADMIN PANEL LAYOUT SYSTEM
   Sidebar + Topbar + Content + Modals + Toasts
   ═══════════════════════════════════════════════════════════════ */

/* ── Admin Body ── */
.admin-body {
    display: flex;
    min-height: 100vh;
    overflow-x: hidden;
}

.admin-body::before {
    display: none;
}

/* ── Sidebar ── */
.admin-sidebar {
    position: fixed;
    left: 0;
    top: 0;
    bottom: 0;
    width: 260px;
    background: linear-gradient(180deg, rgba(10, 13, 12, 0.99) 0%, rgba(6, 8, 7, 1) 100%);
    border-right: 1px solid rgba(255, 255, 255, 0.07);
    display: flex;
    flex-direction: column;
    z-index: 1000;
    transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1), transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
}

.admin-sidebar.collapsed {
    width: 68px;
}

.admin-sidebar__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    min-height: 64px;
}

.admin-sidebar__logo {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    overflow: hidden;
}

.admin-sidebar__logo-img {
    width: 36px;
    height: 36px;
    border-radius: var(--radius-md);
    object-fit: cover;
    flex-shrink: 0;
}

.admin-sidebar__logo-text {
    display: flex;
    flex-direction: column;
    white-space: nowrap;
}

.admin-sidebar__logo-text span:first-child {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--color-white);
}

.admin-sidebar__logo-text span:last-child {
    font-size: 0.7rem;
    color: var(--color-primary-light);
    letter-spacing: 0.04em;
}

.admin-sidebar__close {
    display: none;
    background: none;
    border: none;
    color: var(--color-gray-400);
    font-size: 1.2rem;
    cursor: pointer;
    padding: 0.25rem;
}

.admin-sidebar.collapsed .admin-sidebar__logo-text,
.admin-sidebar.collapsed .admin-sidebar__section-label {
    opacity: 0;
    width: 0;
    overflow: hidden;
}

.admin-sidebar.collapsed .admin-sidebar__link span,
.admin-sidebar.collapsed .admin-sidebar__link {
    justify-content: center;
}

/* ── Sidebar Nav ── */
.admin-sidebar__nav {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 0.5rem 0;
    scrollbar-width: thin;
    scrollbar-color: rgba(255, 255, 255, 0.1) transparent;
}

.admin-sidebar__section {
    padding: 0.5rem 0;
}

.admin-sidebar__section-label {
    display: block;
    font-family: var(--font-heading);
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-gray-600);
    padding: 0.5rem 1.15rem 0.35rem;
    white-space: nowrap;
    transition: opacity 0.2s;
}

.admin-sidebar__link {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.55rem 1.15rem;
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--color-gray-400);
    text-decoration: none;
    border: none;
    background: none;
    width: 100%;
    cursor: pointer;
    transition: all 0.15s ease;
    white-space: nowrap;
    border-left: 3px solid transparent;
}

.admin-sidebar__link:hover {
    color: var(--color-white);
    background: rgba(255, 255, 255, 0.04);
}

.admin-sidebar__link.active {
    color: var(--color-primary-light);
    background: rgba(0, 162, 89, 0.08);
    border-left-color: var(--color-primary);
}

.admin-sidebar__link svg {
    flex-shrink: 0;
    opacity: 0.7;
}

.admin-sidebar__link.active svg,
.admin-sidebar__link:hover svg {
    opacity: 1;
}

.admin-sidebar__link--logout {
    color: var(--color-gray-500);
}

.admin-sidebar__link--logout:hover {
    color: #ff7b7b;
    background: rgba(255, 80, 80, 0.06);
}

/* ── Sidebar Footer ── */
.admin-sidebar__footer {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding: 0.5rem 0;
}

.admin-sidebar__logout {
    width: 100%;
}

/* ── Admin Main ── */
.admin-main {
    margin-left: 260px;
    flex: 1;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    transition: margin-left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    background: var(--color-bg);
}

.admin-main.sidebar-collapsed {
    margin-left: 68px;
}

/* ── Admin Topbar ── */
.admin-topbar {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.5rem;
    height: 60px;
    background: rgba(8, 10, 10, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.admin-topbar__left {
    display: flex;
    align-items: center;
    gap: 1rem;
}

.admin-topbar__toggle {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 6px;
    background: none;
    border: none;
    cursor: pointer;
}

.admin-topbar__toggle span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--color-gray-400);
    border-radius: 2px;
    transition: all 0.2s;
}

.admin-topbar__toggle:hover span {
    background: var(--color-white);
}

.admin-topbar__breadcrumb {
    font-size: 0.85rem;
    color: var(--color-gray-400);
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.admin-topbar__breadcrumb a {
    color: var(--color-gray-500);
    text-decoration: none;
}

.admin-topbar__breadcrumb a:hover {
    color: var(--color-primary-light);
}

.admin-topbar__breadcrumb .sep {
    color: var(--color-gray-700);
}

.admin-topbar__right {
    display: flex;
    align-items: center;
    gap: 1rem;
}

.admin-topbar__user {
    display: flex;
    align-items: center;
    gap: 0.6rem;
}

.admin-topbar__avatar {
    width: 34px;
    height: 34px;
    border-radius: var(--radius-full);
    background: var(--gradient-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.8rem;
    color: white;
}

.admin-topbar__user-info {
    display: flex;
    flex-direction: column;
}

.admin-topbar__user-name {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-white);
}

.admin-topbar__user-role {
    font-size: 0.7rem;
    color: var(--color-primary-light);
}

/* ── Admin Content ── */
.admin-content {
    flex: 1;
    padding: 1.5rem;
}

/* ── Admin Page Header ── */
.admin-page-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
}

.admin-page-header__info h1 {
    font-size: clamp(1.4rem, 2.2vw, 1.8rem);
    margin: 0 0 0.25rem;
}

.admin-page-header__info p {
    color: var(--color-gray-400);
    font-size: 0.9rem;
    margin: 0;
}

.admin-page-header__actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    align-items: center;
}

/* ── Admin KPI Cards ── */
.admin-kpi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
}

.admin-kpi {
    position: relative;
    display: block;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    border-radius: var(--radius-lg);
    padding: 1.25rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: linear-gradient(145deg, rgba(18, 21, 20, 0.95), rgba(11, 13, 12, 0.98));
    box-shadow: var(--shadow-sm);
    transition: all 0.25s ease;
}

.admin-kpi:hover {
    border-color: rgba(0, 162, 89, 0.2);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
}

.admin-kpi::after {
    content: '';
    position: absolute;
    right: -20px;
    bottom: -20px;
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(125, 240, 185, 0.15) 0%, transparent 70%);
    pointer-events: none;
}

.admin-kpi__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: var(--radius-md);
    background: var(--color-primary-muted);
    color: var(--color-primary-light);
    margin-bottom: 0.8rem;
}

.admin-kpi__label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-gray-500);
    margin-bottom: 0.25rem;
}

.admin-kpi__value {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--color-white);
    line-height: 1.1;
}

.admin-kpi__trend {
    margin-top: 0.4rem;
    font-size: 0.75rem;
    color: #94ffca;
}

.admin-kpi__trend--neutral {
    color: var(--color-gray-500);
}

/* ── Admin Cards / Panels ── */
.admin-card {
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-lg);
    background: linear-gradient(150deg, rgba(18, 21, 20, 0.95), rgba(11, 13, 12, 0.98));
    overflow: hidden;
}

.admin-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.admin-card__header h2,
.admin-card__header h3 {
    font-size: 1rem;
    margin: 0;
}

.admin-card__body {
    padding: 1.25rem;
}

.admin-card__body--flush {
    padding: 0;
}

/* ── Admin Data Tables ── */
.admin-table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
}

.admin-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    font-size: 0.85rem;
}

.admin-table thead th {
    position: sticky;
    top: 0;
    text-align: left;
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gray-400);
    background: rgba(255, 255, 255, 0.03);
    padding: 0.75rem 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    white-space: nowrap;
}

.admin-table tbody td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    color: var(--color-gray-300);
    vertical-align: middle;
}

.admin-table tbody tr {
    transition: background 0.15s;
}

.admin-table tbody tr:hover td {
    background: rgba(0, 162, 89, 0.04);
}

.admin-table tbody tr:last-child td {
    border-bottom: none;
}

.admin-table .cell-primary {
    color: var(--color-white);
    font-weight: 600;
}

.admin-table .cell-mono {
    font-family: 'SF Mono', 'Cascadia Code', 'Consolas', monospace;
    font-size: 0.8rem;
    color: var(--color-primary-light);
}

.admin-table .cell-actions {
    white-space: nowrap;
    display: flex;
    gap: 0.35rem;
    align-items: center;
}

/* ── Status Chips (enhanced) ── */
.chip--info {
    color: #b0d4ff;
    border-color: rgba(70, 160, 255, 0.4);
    background: rgba(30, 80, 140, 0.25);
}

.chip--primary {
    color: var(--color-primary-light);
    border-color: rgba(0, 162, 89, 0.4);
    background: rgba(0, 80, 45, 0.25);
}

/* ── Admin Tabs ── */
.admin-tabs {
    display: flex;
    gap: 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    margin-bottom: 1.25rem;
    overflow-x: auto;
}

.admin-tabs__tab {
    padding: 0.7rem 1.25rem;
    font-family: var(--font-heading);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-gray-500);
    text-decoration: none;
    border-bottom: 2px solid transparent;
    transition: all 0.2s;
    white-space: nowrap;
    cursor: pointer;
    background: none;
    border-top: none;
    border-left: none;
    border-right: none;
}

.admin-tabs__tab:hover {
    color: var(--color-gray-200);
}

.admin-tabs__tab.active {
    color: var(--color-primary-light);
    border-bottom-color: var(--color-primary);
}

/* ── Modal ── */
.admin-modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 2000;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    opacity: 0;
    transition: opacity 0.3s ease;
}

.admin-modal-overlay.visible {
    opacity: 1;
}

.admin-modal {
    background: linear-gradient(160deg, rgba(20, 24, 22, 0.99), rgba(10, 12, 11, 1));
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-xl);
    width: 100%;
    max-width: 640px;
    max-height: 85vh;
    overflow-y: auto;
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.5);
    transform: translateY(20px) scale(0.97);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.admin-modal-overlay.visible .admin-modal {
    transform: translateY(0) scale(1);
}

.admin-modal__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}

.admin-modal__title {
    font-size: 1.1rem;
    margin: 0;
    color: var(--color-white);
}

.admin-modal__close {
    background: none;
    border: none;
    color: var(--color-gray-400);
    font-size: 1.5rem;
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    line-height: 1;
    transition: color 0.15s;
}

.admin-modal__close:hover {
    color: var(--color-white);
}

.admin-modal__body {
    padding: 1.5rem;
}

/* ── Modal Form Layout ── */
.modal-form {
    display: grid;
    gap: 1rem;
}

.modal-form .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
}

.modal-form .form-row--full {
    grid-template-columns: 1fr;
}

.modal-form .form-group {
    margin-bottom: 0;
}

.modal-form .form-actions {
    display: flex;
    gap: 0.5rem;
    justify-content: flex-end;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
}

/* ── Toast Notifications ── */
.admin-toast-container {
    position: fixed;
    top: 72px;
    right: 1.5rem;
    z-index: 3000;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-width: 400px;
    pointer-events: none;
}

.admin-toast {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.85rem 1rem;
    border-radius: var(--radius-md);
    background: rgba(18, 22, 20, 0.97);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.4);
    color: var(--color-gray-200);
    font-size: 0.85rem;
    pointer-events: all;
    opacity: 0;
    transform: translateX(30px);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.admin-toast.visible {
    opacity: 1;
    transform: translateX(0);
}

.admin-toast--success {
    border-color: rgba(50, 235, 148, 0.3);
}

.admin-toast--success .admin-toast__icon {
    color: #5eff9e;
}

.admin-toast--error {
    border-color: rgba(255, 105, 105, 0.3);
}

.admin-toast--error .admin-toast__icon {
    color: #ff7b7b;
}

.admin-toast--warning {
    border-color: rgba(255, 193, 7, 0.3);
}

.admin-toast--warning .admin-toast__icon {
    color: #ffd54f;
}

.admin-toast__icon {
    flex-shrink: 0;
    color: var(--color-primary-light);
}

.admin-toast__message {
    flex: 1;
}

.admin-toast__close {
    background: none;
    border: none;
    color: var(--color-gray-500);
    font-size: 1.2rem;
    cursor: pointer;
    padding: 0 0.25rem;
    line-height: 1;
}

/* ── Empty State ── */
.admin-empty {
    text-align: center;
    padding: 3rem 1.5rem;
    color: var(--color-gray-500);
}

.admin-empty__icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    opacity: 0.5;
}

.admin-empty__text {
    font-size: 0.9rem;
    margin-bottom: 1rem;
}

/* ── Admin Grid Layouts ── */
.admin-grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
}

.admin-grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
}

/* ── Quick Actions Row ── */
.admin-quick-actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
}

/* ── Inline Action Buttons ── */
.btn--xs {
    padding: 0.3rem 0.6rem;
    font-size: 0.72rem;
    border-radius: var(--radius-sm);
}

.btn--icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    padding: 0;
    border-radius: var(--radius-md);
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: transparent;
    color: var(--color-gray-400);
    cursor: pointer;
    transition: all 0.15s;
}

.btn--icon:hover {
    background: rgba(255, 255, 255, 0.06);
    color: var(--color-white);
    border-color: rgba(255, 255, 255, 0.2);
}

.btn--icon-danger:hover {
    background: rgba(255, 70, 70, 0.1);
    color: #ff7b7b;
    border-color: rgba(255, 70, 70, 0.3);
}

/* ── Activity/Timeline ── */
.admin-activity {
    display: flex;
    flex-direction: column;
    gap: 0;
}

.admin-activity__item {
    display: flex;
    gap: 0.75rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
}

.admin-activity__item:last-child {
    border-bottom: none;
}

.admin-activity__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-primary);
    margin-top: 6px;
    flex-shrink: 0;
}

.admin-activity__content {
    flex: 1;
}

.admin-activity__text {
    font-size: 0.85rem;
    color: var(--color-gray-300);
}

.admin-activity__time {
    font-size: 0.72rem;
    color: var(--color-gray-600);
    margin-top: 0.2rem;
}

/* ── Responsive Admin ── */
@media (max-width: 1024px) {
    .admin-sidebar {
        transform: translateX(-100%);
        width: 280px;
        box-shadow: 8px 0 30px rgba(0, 0, 0, 0.4);
    }

    .admin-sidebar.mobile-open {
        transform: translateX(0);
    }

    .admin-sidebar__close {
        display: block;
    }

    .admin-main {
        margin-left: 0;
    }

    .admin-main.sidebar-collapsed {
        margin-left: 0;
    }

    .admin-kpi-grid {
        grid-template-columns: repeat(2, 1fr);
    }

    .admin-grid-2,
    .admin-grid-3 {
        grid-template-columns: 1fr;
    }

    .modal-form .form-row {
        grid-template-columns: 1fr;
    }

    .admin-topbar__user-info {
        display: none;
    }
}

@media (max-width: 640px) {
    .admin-content {
        padding: 1rem;
    }

    .admin-kpi-grid {
        grid-template-columns: 1fr;
    }

    .admin-page-header {
        flex-direction: column;
    }

    .admin-page-header__actions {
        width: 100%;
    }
}

/* ── Light Theme Admin Overrides ── */
html[data-theme="light"] .admin-sidebar {
    background: linear-gradient(180deg, #ffffff 0%, #f8faf9 100%);
    border-right-color: rgba(0, 80, 40, 0.1);
}

html[data-theme="light"] .admin-sidebar__link {
    color: var(--color-gray-600);
}

html[data-theme="light"] .admin-sidebar__link:hover {
    color: var(--color-dark);
    background: rgba(0, 162, 89, 0.06);
}

html[data-theme="light"] .admin-sidebar__link.active {
    color: var(--color-primary-dark);
    background: rgba(0, 162, 89, 0.1);
}

html[data-theme="light"] .admin-sidebar__section-label {
    color: var(--color-gray-500);
}

html[data-theme="light"] .admin-topbar {
    background: rgba(255, 255, 255, 0.9);
    border-bottom-color: rgba(0, 80, 40, 0.1);
}

html[data-theme="light"] .admin-topbar__toggle span {
    background: var(--color-gray-500);
}

html[data-theme="light"] .admin-kpi {
    background: linear-gradient(145deg, #ffffff, #f1f8f4);
    border-color: rgba(0, 92, 49, 0.12);
}

html[data-theme="light"] .admin-card {
    background: #ffffff;
    border-color: rgba(0, 92, 49, 0.1);
}

html[data-theme="light"] .admin-card__header {
    border-bottom-color: rgba(0, 80, 40, 0.08);
}

html[data-theme="light"] .admin-table thead th {
    background: rgba(0, 162, 89, 0.06);
    color: var(--color-gray-600);
}

html[data-theme="light"] .admin-table tbody td {
    color: var(--color-gray-700);
    border-bottom-color: rgba(0, 80, 40, 0.06);
}

html[data-theme="light"] .admin-modal {
    background: #ffffff;
    border-color: rgba(0, 80, 40, 0.15);
}

html[data-theme="light"] .admin-toast {
    background: #ffffff;
    border-color: rgba(0, 80, 40, 0.15);
    color: var(--color-gray-700);
}

/* ═══════════════════════════════════════════════════════════════
   PREMIUM LAYER — added Phase 10 frontend overhaul.
   Builds on the design tokens above with editorial typography,
   paper-like surfaces, refined shadows, and motion-aware
   reveal hooks for Motion One.
   ═══════════════════════════════════════════════════════════════ */

/* ── Reveal hooks (used by Motion One in main.js) ── */
.reveal { opacity: 0; transform: translateY(24px); }
.reveal-stagger > * { opacity: 0; transform: translateY(24px); }
.reveal-fade { opacity: 0; }

/* ── Premium navigation ── */
.nav.nav--premium {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    background: rgba(251, 250, 246, 0.85);
    backdrop-filter: saturate(160%) blur(14px);
    -webkit-backdrop-filter: saturate(160%) blur(14px);
    border-bottom: 1px solid transparent;
    transition: background var(--transition-base), border-color var(--transition-base), box-shadow var(--transition-base);
}
.nav.nav--premium.is-scrolled {
    background: rgba(255, 255, 255, 0.95);
    border-bottom-color: var(--color-line);
    box-shadow: var(--shadow-sm);
}
.nav.nav--premium .nav__inner {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: 0.9rem 2rem;
    display: flex;
    align-items: center;
    gap: 2rem;
}
.nav.nav--premium .nav__logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-weight: 600;
}
.nav.nav--premium .nav__logo-image {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: cover;
    background: var(--color-paper);
    box-shadow: var(--shadow-sm);
}
.nav.nav--premium .nav__logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
}
.nav.nav--premium .nav__logo-text span:first-child {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-ink);
}
.nav.nav--premium .nav__logo-text span:last-child {
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 500;
    color: var(--color-primary-dark);
}
.nav.nav--premium .nav__links {
    list-style: none;
    display: flex;
    gap: 0.25rem;
    margin: 0 auto 0 0;
    padding: 0;
}
.nav.nav--premium .nav__links a {
    display: inline-block;
    padding: 0.55rem 0.95rem;
    color: var(--color-ink-soft);
    font-size: 0.92rem;
    font-weight: 500;
    border-radius: var(--radius-full);
    transition: all var(--transition-fast);
    letter-spacing: 0.005em;
}
.nav.nav--premium .nav__links a:hover {
    color: var(--color-primary-dark);
    background: var(--color-primary-soft);
}
.nav.nav--premium .nav__links a.active {
    color: var(--color-primary-dark);
    background: var(--color-primary-soft);
}
.nav.nav--premium .nav__cta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

/* ── Buttons (V2 spec — Syne uppercase) ── */
.btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    padding: 13px 30px;
    border-radius: var(--radius-md);
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 0.8125rem;          /* 13px */
    line-height: 1;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    cursor: pointer;
    border: 1.5px solid transparent;
    transition: transform var(--dur-fast) var(--ease-out),
                background var(--dur-fast) var(--ease-out),
                color var(--dur-fast) var(--ease-out),
                box-shadow var(--dur-normal) var(--ease-out),
                border-color var(--dur-fast) var(--ease-out);
    text-decoration: none;
    white-space: nowrap;
}
.btn:hover { transform: translateY(-2px); }
.btn:active { transform: translateY(0); }

.btn--primary {
    background: var(--green);
    color: var(--white);
    box-shadow: var(--shadow-green);
    border-color: transparent;
}
.btn--primary:hover {
    background: var(--green-dark);
    color: var(--white);
    box-shadow: 0 12px 36px rgba(0, 166, 81, 0.36);
}

.btn--outline,
.btn--secondary {
    background: transparent;
    color: var(--black);
    border: 1.5px solid var(--black);
}
.btn--outline:hover,
.btn--secondary:hover {
    background: var(--black);
    color: var(--white);
}

.btn--ghost {
    background: rgba(255, 255, 255, 0.10);
    color: var(--white);
    border: 1px solid rgba(255, 255, 255, 0.35);
    backdrop-filter: blur(6px);
}
.btn--ghost:hover {
    background: rgba(255, 255, 255, 0.20);
    color: var(--white);
}

/* On-light ghost variant for subtle inline actions (e.g. Logout, View) */
.btn--quiet {
    background: transparent;
    color: var(--ash);
    border: 1px solid transparent;
}
.btn--quiet:hover {
    color: var(--green-dark);
    background: var(--green-tint);
}

.btn--dark {
    background: var(--black);
    color: var(--white);
}
.btn--dark:hover {
    background: var(--green-deeper);
    color: var(--white);
}

.btn--sm { padding: 9px 18px;  font-size: 0.75rem;   letter-spacing: 0.06em; }
.btn--lg { padding: 16px 36px; font-size: 0.875rem;  letter-spacing: 0.08em; }

.btn--with-icon svg {
    width: 1rem; height: 1rem;
    transition: transform var(--dur-fast) var(--ease-out);
}
.btn--with-icon:hover svg { transform: translateX(3px); }

/* ── Editorial section ── */
.section { padding: var(--space-section) 0; }
.section--band {
    background: var(--color-band);
}
.section--forest {
    background: var(--gradient-forest);
    color: var(--color-paper);
}
.section--forest h1, .section--forest h2,
.section--forest h3, .section--forest h4 { color: var(--color-paper); }
.section--forest .eyebrow { color: var(--color-primary-glow); }
.section--forest p { color: rgba(255,255,255,0.78); }
.section-label {
    margin-bottom: 0.85rem;
}
.section-title {
    font-family: var(--font-display);
    font-size: var(--text-headline);
    font-weight: 500;
    letter-spacing: -0.005em;
    color: var(--black);
    margin: 0 0 1rem;
    line-height: var(--leading-tight);
}
.section-subtitle {
    font-family: var(--font-body);
    color: var(--ash);
    max-width: 720px;
    font-size: var(--text-lead);
    line-height: var(--leading-body);
    font-weight: 300;
}

/* ── Premium hero (V2 — cinematic, bottom-anchored, Ken Burns) ── */
.hero--premium {
    position: relative;
    height: 100vh;
    min-height: 640px;
    display: flex;
    align-items: flex-end;     /* content hugs the bottom (cinematic) */
    color: var(--white);
    overflow: hidden;
    isolation: isolate;
    background: var(--black);
}
.hero--premium .hero__bg {
    position: absolute; inset: 0; z-index: -2;
}
/* Ken Burns slow-zoom — 16s, alternating, smooth ease-in-out */
.hero--premium .hero__bg img {
    width: 100%; height: 100%; object-fit: cover;
    object-position: center 30%;
    animation: kenBurns 16s ease-in-out infinite alternate;
    will-change: transform;
}
@keyframes kenBurns {
    from { transform: scale(1.0); }
    to   { transform: scale(1.08); }
}
@media (prefers-reduced-motion: reduce) {
    .hero--premium .hero__bg img { animation: none; }
}
/* Stronger bottom-up overlay so the bottom-anchored copy reads against any photo */
.hero--premium .hero__overlay {
    position: absolute; inset: 0; z-index: -1;
    background: linear-gradient(
        to top,
        rgba(0, 0, 0, 0.80) 0%,
        rgba(0, 0, 0, 0.35) 40%,
        rgba(0, 0, 0, 0.08) 100%
    );
}
/* Full-bleed wrapper, content sits in the lower-left */
.hero--premium .container {
    max-width: var(--container-wide);
    width: 100%;
    padding: 0 60px 52px;
}
@media (max-width: 768px) {
    .hero--premium .container { padding: 0 1.5rem 2.5rem; }
}
/* Slightly compact heroes (page-headers like /art-store, /contact) keep
   the same cinematic treatment but reduce min-height. */
.hero--premium[style*="min-height:54vh"],
.hero--premium[style*="min-height:56vh"],
.hero--premium[style*="min-height:50vh"],
.hero--premium[style*="min-height:60vh"],
.hero--premium[style*="min-height:62vh"] {
    height: auto;
    min-height: 520px;
}
.hero--premium .hero__tagline {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    color: var(--green-mid);
    font-family: var(--font-ui);
    font-size: 0.7rem;                /* 11.2px */
    font-weight: 600;
    letter-spacing: var(--track-wider);
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    text-shadow: 0 1px 2px rgba(0,0,0,0.35);
}
.hero--premium .hero__tagline::before {
    content: '';
    width: 36px; height: 1px;
    background: currentColor;
    opacity: 0.85;
}
.hero--premium .hero__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 6rem);
    font-weight: 700;
    line-height: 1.02;
    letter-spacing: -0.015em;
    color: var(--white);
    max-width: 16ch;
    margin: 0 0 1.5rem;
    text-shadow: 0 2px 6px rgba(0,0,0,0.30);
}
.hero--premium .hero__title .accent {
    font-style: italic;
    font-weight: 300;
    color: var(--green-mid);
}
.hero--premium .hero__desc {
    font-family: var(--font-body);
    font-weight: 400;
    color: rgba(255, 255, 255, 0.92);
    max-width: 580px;
    font-size: 1.15rem;
    line-height: 1.6;
    margin-bottom: 2.25rem;
    text-shadow: 0 1px 3px rgba(0,0,0,0.30);
}
.hero--premium .hero__actions {
    display: flex; flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 0;       /* anchored to bottom; nothing under */
}
.hero--premium .hero__stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.75rem;
    max-width: 580px;
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.20);
}
.hero--premium .hero__stat-value {
    font-family: var(--font-mono);
    font-size: 2.5rem;
    font-weight: 400;
    color: var(--white);
    line-height: 1;
    font-feature-settings: "tnum";
}
.hero--premium .hero__stat-label {
    font-family: var(--font-ui);
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: var(--track-wide);
    text-transform: uppercase;
    margin-top: 0.5rem;
}

/* Hero bottom-fade vignette on the LEFT for extra depth on busy photos */
.hero--premium::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(to right, rgba(0,0,0,0.30) 0%, transparent 45%);
    pointer-events: none;
}

/* Trust strip under hero */
.trust-strip {
    background: var(--color-paper);
    border-bottom: 1px solid var(--color-line);
    padding: 1.25rem 0;
}
.trust-strip__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: 0 2rem;
}
.trust-strip__item {
    display: flex; align-items: center; gap: 0.6rem;
    color: var(--color-ink-soft);
    font-size: 0.92rem;
    font-weight: 500;
}
.trust-strip__item strong {
    color: var(--color-ink);
    font-weight: 700;
}
.trust-strip__item svg {
    width: 18px; height: 18px;
    color: var(--color-primary);
}

/* ── Why-choose-us pillars ── */
.pillars {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
    margin-top: 3rem;
}
.pillar {
    background: var(--white);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    padding: 2rem 1.75rem;
    transition: transform var(--dur-normal) var(--ease-out),
                box-shadow var(--dur-normal) var(--ease-out),
                border-color var(--dur-normal) var(--ease-out);
}
.pillar:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--green-mid);
}
.pillar__icon {
    width: 52px; height: 52px;
    border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    background: var(--green-tint);
    color: var(--green-dark);
    margin-bottom: 1.25rem;
}
.pillar__icon svg { width: 26px; height: 26px; }
.pillar__title {
    font-family: var(--font-display);
    font-size: 1.625rem;            /* 26px */
    font-weight: 600;
    color: var(--black);
    margin: 0 0 0.55rem;
    line-height: 1.2;
}
.pillar__text {
    font-family: var(--font-body);
    color: var(--ash);
    font-size: 0.9375rem;
    line-height: 1.65;
    margin: 0;
    font-weight: 400;
}

/* ── Department cards (rich, editorial) ── */
.dept-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.5rem;
}
.dept-card {
    background: var(--white);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex; flex-direction: column;
    transition: transform var(--dur-normal) var(--ease-out),
                box-shadow var(--dur-normal) var(--ease-out);
}
.dept-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-xl);
}
.dept-card__media {
    aspect-ratio: 16 / 10;
    background: var(--green-tint);
    overflow: hidden;
    position: relative;
}
.dept-card__media img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform var(--dur-slow) var(--ease-out);
}
.dept-card:hover .dept-card__media img { transform: scale(1.06); }
.dept-card__badge {
    position: absolute; top: 1rem; left: 1rem;
    padding: 0.4rem 0.85rem;
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(6px);
    font-family: var(--font-ui);
    font-size: 0.625rem;          /* 10px */
    letter-spacing: var(--track-wider);
    text-transform: uppercase;
    color: var(--green-dark);
    font-weight: 600;
}
.dept-card__body { padding: 1.6rem 1.75rem 1.85rem; }
.dept-card__title {
    font-family: var(--font-display);
    font-size: 1.625rem;          /* 26px */
    font-weight: 600;
    color: var(--black);
    margin: 0 0 0.6rem;
    line-height: 1.2;
}
.dept-card__text {
    font-family: var(--font-body);
    color: var(--ash);
    font-size: 0.9375rem;
    line-height: 1.65;
    margin: 0 0 1rem;
}
.dept-card__list {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
}
.dept-card__list li {
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    letter-spacing: var(--track-wide);
    text-transform: uppercase;
    padding: 0.4rem 0.75rem;
    background: var(--green-tint);
    color: var(--green-deeper);
    border-radius: var(--radius-pill);
    font-weight: 500;
}
.dept-card__cta {
    margin-top: 1.25rem;
    font-family: var(--font-ui);
    color: var(--green-dark);
    font-weight: 600;
    font-size: 0.75rem;
    letter-spacing: var(--track-wide);
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    transition: gap var(--dur-fast) var(--ease-out);
}
.dept-card__cta:hover { gap: 0.7rem; }

/* ── Product / Experience cards (refined) ── */
.card.card--editorial {
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex; flex-direction: column;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
}
.card.card--editorial:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
}
.card.card--editorial .card__image {
    position: relative;
    aspect-ratio: 4/5;
    overflow: hidden;
    background: var(--color-tint);
}
.card.card--editorial .card__image img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 700ms cubic-bezier(.22,.61,.36,1);
}
.card.card--editorial:hover .card__image img { transform: scale(1.05); }
.card.card--editorial .card__badge {
    position: absolute; top: 0.85rem; left: 0.85rem;
    background: var(--color-paper);
    color: var(--color-primary-dark);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.3rem 0.65rem;
    border-radius: var(--radius-full);
    box-shadow: var(--shadow-sm);
}
.card.card--editorial .card__body {
    padding: 1.25rem 1.4rem 1.4rem;
    display: flex; flex-direction: column;
    flex: 1;
}
.card.card--editorial .card__category {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-primary-dark);
    margin-bottom: 0.45rem;
}
.card.card--editorial .card__title {
    font-family: var(--font-display);
    font-size: 1.125rem;         /* 18px (V2 art card) */
    font-weight: 600;
    color: var(--black);
    margin: 0 0 0.35rem;
    line-height: 1.2;
}
.card.card--editorial .card__title a { color: inherit; }
.card.card--editorial .card__title a:hover { color: var(--green-dark); }
.card.card--editorial .card__text {
    font-family: var(--font-body);
    color: var(--ash);
    font-size: 0.8125rem;        /* 13px */
    line-height: 1.55;
}
/* Prices (V2 hard rule: DM Mono, --green) */
.card.card--editorial .card__price,
.card.card--editorial [data-price] {
    font-family: var(--font-mono);
    font-feature-settings: "tnum";
    color: var(--green);
    font-size: 1.0625rem;
    font-weight: 500;
}
/* Status dot before category */
.card.card--editorial .card__category {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
}
.card.card--editorial .card__category::before {
    content: '';
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--green);
}

/* ── Testimonial ── */
.testimonial {
    background: var(--color-paper);
    border-left: 3px solid var(--color-primary);
    padding: 2rem 2.25rem;
    border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
    box-shadow: var(--shadow-sm);
}
.testimonial__quote {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.2rem;
    line-height: 1.55;
    color: var(--color-ink-soft);
    margin: 0 0 1.25rem;
}
.testimonial__author {
    display: flex; align-items: center; gap: 0.85rem;
}
.testimonial__avatar {
    width: 44px; height: 44px;
    border-radius: 50%;
    background: var(--color-primary-soft);
    color: var(--color-primary-dark);
    display: flex; align-items: center; justify-content: center;
    font-weight: 700;
    font-family: var(--font-display);
}
.testimonial__name { font-weight: 600; color: var(--color-ink); }
.testimonial__role { font-size: 0.85rem; color: var(--color-ink-faint); }

/* ── CTA strip ── */
.cta-strip {
    background: var(--gradient-forest);
    color: var(--color-paper);
    padding: clamp(3rem, 6vw, 5rem) 0;
}
.cta-strip__inner {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: center;
}
.cta-strip__title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 500;
    color: var(--color-paper);
    margin: 0 0 0.5rem;
    letter-spacing: -0.01em;
    line-height: 1.15;
}
.cta-strip__sub {
    color: rgba(255,255,255,0.78);
    font-size: 1rem;
    margin: 0;
    max-width: 560px;
}
@media (max-width: 768px) {
    .cta-strip__inner { grid-template-columns: 1fr; }
}

/* ── Footer (premium) ── */
.footer {
    background: var(--color-ink);
    color: rgba(255,255,255,0.7);
    padding: 4rem 0 2rem;
    margin-top: 0;
}
.footer .container { max-width: var(--container-wide); padding: 0 2rem; }
.footer__newsletter {
    background: var(--color-primary-deeper);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
    margin-bottom: 3rem;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: center;
}
.footer__newsletter h3 {
    font-family: var(--font-display);
    color: var(--color-paper);
    font-size: 1.6rem;
    font-weight: 500;
    margin: 0 0 0.4rem;
}
.footer__newsletter p {
    color: rgba(255,255,255,0.7);
    margin: 0;
    font-size: 0.95rem;
}
.footer__newsletter form {
    display: flex; gap: 0.5rem;
    background: rgba(255,255,255,0.08);
    padding: 0.4rem;
    border-radius: var(--radius-full);
    border: 1px solid rgba(255,255,255,0.16);
}
.footer__newsletter input {
    background: transparent;
    border: 0;
    color: var(--color-paper);
    padding: 0.7rem 1rem;
    min-width: 240px;
    font-size: 0.95rem;
    outline: none;
}
.footer__newsletter input::placeholder { color: rgba(255,255,255,0.5); }
.footer__grid {
    display: grid;
    grid-template-columns: 1.4fr repeat(3, 1fr);
    gap: 3rem;
}
@media (max-width: 900px) {
    .footer__grid { grid-template-columns: 1fr 1fr; }
    .footer__newsletter { grid-template-columns: 1fr; }
}
.footer__brand p { color: rgba(255,255,255,0.65); margin: 1rem 0 1.25rem; max-width: 360px; font-size: 0.95rem; }
.footer__heading {
    font-family: var(--font-display);
    color: var(--color-paper);
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 1.1rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
}
.footer__links { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.55rem; }
.footer__links a, .footer__links li {
    color: rgba(255,255,255,0.7);
    font-size: 0.93rem;
    transition: color var(--transition-fast);
}
.footer__links a:hover { color: var(--color-primary-glow); }
.footer__social { display: flex; gap: 0.5rem; margin-top: 1rem; }
.footer__social a {
    width: 38px; height: 38px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 50%;
    background: rgba(255,255,255,0.06);
    color: var(--color-paper);
    transition: all var(--transition-fast);
}
.footer__social a:hover {
    background: var(--color-primary);
    transform: translateY(-2px);
}
.footer__bottom {
    border-top: 1px solid rgba(255,255,255,0.08);
    padding-top: 1.5rem;
    margin-top: 3rem;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    color: rgba(255,255,255,0.5);
    font-size: 0.85rem;
}
.footer .nav__logo { color: var(--color-paper); }
.footer .nav__logo-text span:first-child { color: var(--color-paper); }
.footer .nav__logo-text span:last-child { color: var(--color-primary-glow); }

/* ── Premium admin shell ── */
.admin-body { background: var(--color-canvas); color: var(--color-ink); }
.admin-sidebar.admin-sidebar--premium {
    background: var(--color-paper);
    border-right: 1px solid var(--color-line);
    box-shadow: var(--shadow-sm);
}
.admin-sidebar--premium .admin-sidebar__header {
    padding: 1.5rem 1.5rem 1.25rem;
    border-bottom: 1px solid var(--color-line);
    display: flex; justify-content: space-between; align-items: center;
}
.admin-sidebar--premium .admin-sidebar__logo { display: flex; align-items: center; gap: 0.7rem; }
.admin-sidebar--premium .admin-sidebar__logo-img {
    width: 40px; height: 40px;
    border-radius: 50%;
    background: var(--color-primary-soft);
    object-fit: cover;
}
.admin-sidebar--premium .admin-sidebar__logo-text {
    display: flex; flex-direction: column; line-height: 1.05;
}
.admin-sidebar--premium .admin-sidebar__logo-text span:first-child {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--color-ink);
    font-size: 0.98rem;
}
.admin-sidebar--premium .admin-sidebar__logo-text span:last-child {
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-primary-dark);
}
.admin-sidebar--premium .admin-sidebar__nav {
    padding: 1rem 0.85rem;
    display: flex; flex-direction: column; gap: 1.5rem;
}
.admin-sidebar--premium .admin-sidebar__section { display: flex; flex-direction: column; gap: 0.18rem; }
.admin-sidebar--premium .admin-sidebar__section-label {
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-faint);
    padding: 0 0.85rem;
    margin-bottom: 0.45rem;
    font-weight: 600;
}
.admin-sidebar--premium .admin-sidebar__link {
    display: flex; align-items: center; gap: 0.75rem;
    padding: 0.6rem 0.85rem;
    border-radius: 10px;
    color: var(--color-ink-soft);
    font-size: 0.93rem;
    font-weight: 500;
    transition: background var(--transition-fast), color var(--transition-fast);
    position: relative;
}
.admin-sidebar--premium .admin-sidebar__link:hover {
    background: var(--color-primary-soft);
    color: var(--color-primary-dark);
}
.admin-sidebar--premium .admin-sidebar__link.active {
    background: var(--color-primary-soft);
    color: var(--color-primary-dark);
    font-weight: 600;
}
.admin-sidebar--premium .admin-sidebar__link.active::before {
    content: '';
    position: absolute; left: 0;
    top: 6px; bottom: 6px;
    width: 3px;
    border-radius: 0 3px 3px 0;
    background: var(--color-primary);
}
.admin-sidebar--premium .admin-sidebar__footer {
    padding: 1rem 0.85rem;
    border-top: 1px solid var(--color-line);
}

.admin-topbar.admin-topbar--premium {
    background: rgba(255,255,255,0.85);
    backdrop-filter: saturate(160%) blur(14px);
    border-bottom: 1px solid var(--color-line);
    padding: 0.9rem 1.6rem;
    display: flex; align-items: center; justify-content: space-between;
}
.admin-topbar--premium .admin-topbar__breadcrumb {
    font-size: 0.92rem;
    color: var(--color-ink-mute);
    font-weight: 500;
    display: flex; align-items: center; gap: 0.4rem;
}
.admin-topbar--premium .admin-topbar__breadcrumb .sep {
    color: var(--color-ink-faint);
}
.admin-topbar--premium .admin-topbar__breadcrumb a {
    color: var(--color-ink-soft);
}
.admin-topbar--premium .admin-topbar__breadcrumb a:hover {
    color: var(--color-primary-dark);
}
.admin-topbar--premium .admin-topbar__search {
    flex: 1;
    max-width: 380px;
    margin: 0 1.5rem;
    position: relative;
}
.admin-topbar--premium .admin-topbar__search input {
    width: 100%;
    padding: 0.55rem 0.85rem 0.55rem 2.4rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-line);
    background: var(--color-tint);
    font-size: 0.9rem;
    color: var(--color-ink);
    outline: none;
    transition: all var(--transition-fast);
}
.admin-topbar--premium .admin-topbar__search input:focus {
    border-color: var(--color-primary);
    background: var(--color-paper);
    box-shadow: var(--shadow-ring);
}
.admin-topbar--premium .admin-topbar__search svg {
    position: absolute; left: 0.85rem; top: 50%;
    transform: translateY(-50%);
    width: 16px; height: 16px;
    color: var(--color-ink-faint);
}
.admin-topbar--premium .admin-topbar__avatar {
    width: 38px; height: 38px;
    border-radius: 50%;
    background: var(--gradient-primary);
    color: var(--color-paper);
    display: flex; align-items: center; justify-content: center;
    font-weight: 700;
    font-family: var(--font-display);
}
.admin-topbar--premium .admin-topbar__user-name { font-weight: 600; color: var(--color-ink); }
.admin-topbar--premium .admin-topbar__user-role { font-size: 0.78rem; color: var(--color-ink-faint); }

/* Admin page header */
.admin-page-header {
    display: flex; justify-content: space-between; align-items: flex-start;
    flex-wrap: wrap; gap: 1.5rem;
    padding: 2rem 2.25rem 1.5rem;
}
.admin-page-header__info h1 {
    font-family: var(--font-display);
    font-size: 1.85rem;
    font-weight: 500;
    color: var(--color-ink);
    margin: 0 0 0.4rem;
    letter-spacing: -0.01em;
}
.admin-page-header__info p {
    color: var(--color-ink-mute);
    margin: 0;
    font-size: 0.95rem;
}
.admin-page-header__actions { display: flex; gap: 0.5rem; }

.admin-content { padding: 0 2.25rem 3rem; }

/* Admin KPI grid (premium) */
.admin-kpi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.25rem;
    margin-bottom: 2rem;
}
.admin-kpi {
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    padding: 1.5rem 1.5rem 1.25rem;
    position: relative;
    overflow: hidden;
    transition: transform var(--transition-base), box-shadow var(--transition-base), border-color var(--transition-base);
    text-decoration: none;
    display: flex; flex-direction: column; gap: 0.5rem;
}
.admin-kpi:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-primary-light);
}
.admin-kpi__icon {
    width: 42px; height: 42px;
    border-radius: 12px;
    background: var(--color-primary-soft);
    color: var(--color-primary-dark);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 0.65rem;
}
.admin-kpi__label {
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink-faint);
    font-weight: 600;
}
.admin-kpi__value {
    font-family: var(--font-display);
    font-size: 2.1rem;
    font-weight: 500;
    color: var(--color-ink);
    line-height: 1;
}
.admin-kpi__trend {
    color: var(--color-ink-mute);
    font-size: 0.85rem;
    margin-top: 0.3rem;
}
.admin-kpi__sparkline {
    position: absolute;
    inset: auto 1rem 1rem auto;
    width: 80px; height: 28px;
    opacity: 0.6;
}

/* Two-column dashboard layout */
.admin-dashboard-row {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 1.5rem;
    margin-bottom: 2rem;
}
@media (max-width: 1100px) { .admin-dashboard-row { grid-template-columns: 1fr; } }
.admin-panel {
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    box-shadow: var(--shadow-sm);
}
.admin-panel__header {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 1.25rem;
}
.admin-panel__title {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-ink);
    margin: 0;
}
.admin-panel__sub {
    color: var(--color-ink-faint);
    font-size: 0.85rem;
    margin: 0.15rem 0 0;
}
.admin-bar {
    display: flex; flex-direction: column; gap: 0.6rem; margin: 0.75rem 0;
}
.admin-bar__row {
    display: grid;
    grid-template-columns: 130px 1fr 60px;
    gap: 0.75rem; align-items: center;
}
.admin-bar__label {
    font-size: 0.85rem;
    color: var(--color-ink-soft);
    font-weight: 500;
}
.admin-bar__track {
    height: 8px;
    border-radius: var(--radius-full);
    background: var(--color-tint);
    overflow: hidden;
}
.admin-bar__fill {
    height: 100%;
    background: var(--gradient-primary);
    border-radius: var(--radius-full);
    transition: width 800ms cubic-bezier(.22,.61,.36,1);
}
.admin-bar__value {
    text-align: right;
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--color-ink);
}
.admin-quick-actions {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 0.6rem;
}
.admin-quick-actions a {
    padding: 0.85rem 1rem;
    background: var(--color-tint);
    border-radius: 12px;
    color: var(--color-ink-soft);
    font-weight: 500;
    font-size: 0.9rem;
    display: flex; align-items: center; gap: 0.55rem;
    transition: all var(--transition-fast);
    border: 1px solid transparent;
}
.admin-quick-actions a:hover {
    background: var(--color-primary-soft);
    color: var(--color-primary-dark);
    border-color: var(--color-primary-light);
}
.admin-quick-actions svg { width: 16px; height: 16px; color: var(--color-primary); }

/* ── Department detail editorial blocks ── */
.dept-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    padding: 4rem 0;
    border-bottom: 1px solid var(--color-line);
}
.dept-block:last-child { border-bottom: 0; }
.dept-block--reverse .dept-block__media { order: 2; }
@media (max-width: 900px) {
    .dept-block { grid-template-columns: 1fr; gap: 2rem; padding: 3rem 0; }
    .dept-block--reverse .dept-block__media { order: 0; }
}
.dept-block__media {
    aspect-ratio: 4/5;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-tint);
    box-shadow: var(--shadow-lg);
}
.dept-block__media img {
    width: 100%; height: 100%; object-fit: cover;
}
.dept-block__title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 500;
    color: var(--color-ink);
    margin: 0.6rem 0 1rem;
    letter-spacing: -0.015em;
}
.dept-block__intro {
    color: var(--color-ink-soft);
    font-size: 1.08rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
}
.dept-block__sections {
    display: flex; flex-direction: column; gap: 1.25rem;
}
.dept-block__section h4 {
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-primary-dark);
    margin: 0 0 0.5rem;
}
.dept-block__section p {
    color: var(--color-ink-mute);
    font-size: 0.96rem;
    line-height: 1.65;
    margin: 0;
}
.dept-block__chips {
    display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.5rem;
}
.dept-block__chips span {
    padding: 0.4rem 0.85rem;
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-full);
    font-size: 0.82rem;
    color: var(--color-ink-soft);
    font-weight: 500;
}

/* ── Newsletter input button ── */
.newsletter-btn {
    background: var(--color-primary);
    color: var(--color-paper);
    border: 0;
    padding: 0.8rem 1.4rem;
    border-radius: var(--radius-full);
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition-fast);
}
.newsletter-btn:hover { background: var(--color-primary-dark); transform: translateY(-1px); }

/* ── Skip-to-content for accessibility ── */
.skip-link {
    position: absolute; left: -9999px; top: 1rem;
    background: var(--color-primary);
    color: var(--color-paper);
    padding: 0.6rem 1rem; border-radius: var(--radius-md);
    z-index: var(--z-modal);
}
.skip-link:focus { left: 1rem; }

/* ── Hide legacy theme toggle on premium pages — toggle now lives elsewhere ── */
.theme-toggle { display: none !important; }

/* ── Reduced motion ── */
@media (prefers-reduced-motion: reduce) {
    .reveal, .reveal-stagger > *, .reveal-fade { opacity: 1 !important; transform: none !important; }
    *, *::before, *::after { animation-duration: 0.001ms !important; transition-duration: 0.001ms !important; }
}

/* ═══════════════════════════════════════════════════════════════
   V2 ADDITIONS — KPI block, form fields, WhatsApp float,
   trust-strip refinements, error states, mountain divider.
   ═══════════════════════════════════════════════════════════════ */

/* ── KPI / Impact block (V2 spec) ── */
.kpi-strip {
    background: var(--charcoal);
    color: var(--white);
    padding: 3.25rem 0;
}
.kpi-strip__inner {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
}
@media (max-width: 768px) { .kpi-strip__inner { grid-template-columns: repeat(2, 1fr); gap: 2rem 1.5rem; } }
.kpi {
    display: flex; flex-direction: column; gap: 0.4rem;
}
.kpi__value {
    font-family: var(--font-mono);
    font-feature-settings: "tnum";
    font-size: var(--text-headline);
    font-weight: 400;
    color: var(--green);
    line-height: 1;
}
.kpi__label {
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: var(--track-wider);
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
}
.kpi__desc {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.5;
}

/* ── Form fields (V2 spec) ── */
.field {
    display: flex; flex-direction: column; gap: 0.4rem;
}
.field__label {
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: var(--track-wide);
    text-transform: uppercase;
    color: var(--ash);
}
.field input,
.field textarea,
.field select,
input.input,
textarea.input,
select.input {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--black);
    background: var(--white);
    border: 1.5px solid var(--stone);
    border-radius: var(--radius-md);
    padding: 12px 15px;
    width: 100%;
    transition: border-color var(--dur-micro) var(--ease-out),
                box-shadow var(--dur-fast) var(--ease-out);
}
.field input::placeholder,
.field textarea::placeholder,
input.input::placeholder,
textarea.input::placeholder { color: var(--ash); }
.field input:focus,
.field textarea:focus,
.field select:focus,
input.input:focus,
textarea.input:focus,
select.input:focus {
    border-color: var(--green);
    outline: none;
    box-shadow: var(--shadow-ring);
}
.field--error input, .field--error textarea, .field--error select {
    border-color: var(--color-error);
}
.field__error {
    color: var(--color-error);
    font-size: 0.75rem;
    font-family: var(--font-body);
}

/* ── Floating WhatsApp button (mobile only per spec) ── */
.wa-float {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    width: 52px; height: 52px;
    border-radius: 50%;
    background: var(--green);
    color: var(--white);
    display: flex; align-items: center; justify-content: center;
    box-shadow: var(--shadow-green);
    z-index: 900;
    transition: transform var(--dur-fast) var(--ease-out);
}
.wa-float:hover { transform: translateY(-2px); color: var(--white); }
.wa-float svg { width: 24px; height: 24px; }
@media (min-width: 768px) { .wa-float { display: none; } }

/* ── Mountain silhouette divider (decorative) ── */
.mtn-divider {
    width: 100%;
    height: 64px;
    background: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1200 80' preserveAspectRatio='none'><path fill='%2300A651' fill-opacity='0.08' d='M0,80 L160,28 L260,55 L380,15 L520,52 L660,8 L800,40 L920,18 L1060,48 L1200,22 L1200,80 Z'/></svg>") center / cover no-repeat;
}

/* ── Empty / error state branding ── */
.empty-state {
    text-align: center;
    padding: 5rem 1.5rem;
    max-width: 520px;
    margin: 0 auto;
}
.empty-state__title {
    font-family: var(--font-display);
    font-size: var(--text-title);
    font-weight: 600;
    color: var(--black);
    margin: 1.5rem 0 0.75rem;
}
.empty-state__body {
    font-family: var(--font-body);
    color: var(--ash);
    line-height: 1.6;
    margin-bottom: 1.75rem;
}

/* ── Trust strip refinements (V2: ash text, green stat) ── */
.trust-strip {
    background: var(--white);
    border-top: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
    padding: 1.25rem 0;
}
.trust-strip__item {
    font-family: var(--font-body);
    color: var(--ash);
    font-size: 0.875rem;
}
.trust-strip__item strong {
    font-family: var(--font-mono);
    color: var(--green);
    font-weight: 500;
}
.trust-strip__item svg { color: var(--green); }

/* ── Cormorant headline floor (V2 hard rule: never below 18px) ── */
.section-title,
.dept-card__title,
.pillar__title,
.dept-block__title,
.empty-state__title,
.cta-strip__title,
.testimonial__quote,
.hero--premium .hero__title { font-family: var(--font-display); }

/* ── Body / nav links default to Syne uppercase per V2 ── */
.nav.nav--premium .nav__links a {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: var(--track-wide);
    text-transform: uppercase;
}

/* ── Active nav link: animated green underline left-to-right (V2) ── */
.nav.nav--premium .nav__links a {
    position: relative;
    background: transparent;
    border-radius: 0;
    padding: 0.4rem 0.1rem;
    margin: 0 0.6rem;
    color: var(--charcoal);
}
.nav.nav--premium .nav__links a::after {
    content: '';
    position: absolute;
    left: 0; bottom: -4px;
    width: 0; height: 2px;
    background: var(--green);
    transition: width var(--dur-fast) var(--ease-out);
}
.nav.nav--premium .nav__links a:hover,
.nav.nav--premium .nav__links a.active {
    background: transparent;
    color: var(--black);
}
.nav.nav--premium .nav__links a:hover::after,
.nav.nav--premium .nav__links a.active::after { width: 100%; }

/* ── Logo lockup tightening ── */
.nav.nav--premium .nav__logo-text span:first-child {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--black);
}
.nav.nav--premium .nav__logo-text span:last-child {
    font-family: var(--font-ui);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: var(--track-wider);
    color: var(--green-dark);
    text-transform: uppercase;
}

/* ── Footer refinements ── */
.footer__heading {
    font-family: var(--font-ui);
    color: var(--white);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: var(--track-wider);
    text-transform: uppercase;
}
.footer__newsletter h3 {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--white);
    font-size: 1.75rem;
}
.footer__newsletter input {
    font-family: var(--font-body);
}
.newsletter-btn {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: var(--track-wide);
    text-transform: uppercase;
}

/* ── Admin KPI value: DM Mono (V2 prices/data rule) ── */
.admin-kpi__value { font-family: var(--font-mono); font-feature-settings: "tnum"; font-weight: 400; }
.admin-kpi__label { font-family: var(--font-ui); letter-spacing: var(--track-wide); text-transform: uppercase; }

/* ── Earth accent (handcraft category badge) ── */
.tag--earth {
    background: var(--sand);
    color: #6b3a13;
    padding: 0.35rem 0.85rem;
    border-radius: var(--radius-pill);
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    letter-spacing: var(--track-wide);
    text-transform: uppercase;
    font-weight: 600;
}

/* ── Background tokens enforced (V2 hard rule: no gray) ── */
body, html { background: var(--ivory); }
.section--band { background: #EFEDE6; }
.section--ivory { background: var(--ivory); }
.section--white { background: var(--white); }

/* ═══════════════════════════════════════════════════════════════
   V2 RETRO-FIT — automatic upgrades to legacy class names.
   Every existing template inherits V2 typography + color
   without per-template HTML changes.
   ═══════════════════════════════════════════════════════════════ */

/* All prices → DM Mono in --green */
.card__price,
.product-price,
.price-value,
[class*="__price"]:not([class*="-meta"]) {
    font-family: var(--font-mono) !important;
    font-feature-settings: "tnum";
    color: var(--green);
    font-weight: 500;
}

/* Page header (used on art-store, experiences, blog, etc.) */
.page-header {
    background: var(--white);
    border-bottom: 1px solid var(--color-line);
    padding: clamp(3.5rem, 6vw, 6rem) 0 clamp(2.5rem, 4vw, 4rem);
    position: relative;
}
.page-header h1 {
    font-family: var(--font-display);
    font-size: var(--text-headline);
    font-weight: 600;
    color: var(--black);
    margin: 0.65rem 0 0;
    line-height: var(--leading-tight);
    letter-spacing: -0.005em;
}
.page-header p,
.page-header .section-subtitle {
    font-family: var(--font-body);
    color: var(--ash);
    font-size: var(--text-lead);
    line-height: var(--leading-body);
    font-weight: 300;
    max-width: 60ch;
}
.page-header__decor {
    position: absolute;
    inset: auto 0 0 0;
    height: 6px;
    background: var(--gradient-primary);
    opacity: 0.35;
}

/* Breadcrumb V2 */
.breadcrumb {
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: var(--track-wide);
    text-transform: uppercase;
    color: var(--ash);
    margin-bottom: 1rem;
    display: flex; align-items: center; gap: 0.45rem;
}
.breadcrumb a { color: var(--ash); transition: color var(--dur-fast) var(--ease-out); }
.breadcrumb a:hover { color: var(--green-dark); }
.breadcrumb__separator { color: var(--stone); }

/* Generic .card legacy → editorial-equivalent styling */
.card:not(.card--editorial) {
    background: var(--white);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex; flex-direction: column;
    transition: transform var(--dur-normal) var(--ease-out),
                box-shadow var(--dur-normal) var(--ease-out);
}
.card:not(.card--editorial):hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
}
.card:not(.card--editorial) .card__image {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--green-tint);
    position: relative;
}
.card:not(.card--editorial) .card__image img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform var(--dur-slow) var(--ease-out);
}
.card:not(.card--editorial):hover .card__image img { transform: scale(1.04); }
.card:not(.card--editorial) .card__badge {
    position: absolute; top: 0.85rem; left: 0.85rem;
    background: var(--white);
    color: var(--green-dark);
    font-family: var(--font-ui);
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: var(--track-wider);
    text-transform: uppercase;
    padding: 0.35rem 0.7rem;
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-sm);
}
.card:not(.card--editorial) .card__body {
    padding: 1.25rem 1.4rem 1.4rem;
    display: flex; flex-direction: column;
    flex: 1;
    gap: 0.4rem;
}
.card:not(.card--editorial) .card__category {
    font-family: var(--font-ui);
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: var(--track-wider);
    text-transform: uppercase;
    color: var(--green-dark);
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
}
.card:not(.card--editorial) .card__category::before {
    content: '';
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--green);
}
.card:not(.card--editorial) .card__title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--black);
    line-height: 1.2;
    margin: 0;
}
.card:not(.card--editorial) .card__title a { color: inherit; }
.card:not(.card--editorial) .card__title a:hover { color: var(--green-dark); }
.card:not(.card--editorial) .card__text {
    font-family: var(--font-body);
    color: var(--ash);
    font-size: 0.8125rem;
    line-height: 1.55;
    margin: 0;
}
.card:not(.card--editorial) .card__meta {
    margin-top: auto;
    padding-top: 0.85rem;
    display: flex; align-items: center; justify-content: space-between;
    gap: 0.5rem;
}

/* Generic grid spacing */
.grid { display: grid; gap: 1.25rem; }
.grid.grid-2 { grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
.grid.grid-3 { grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); }
.grid.grid-4 { grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); }

/* Form input legacy class → V2 spec */
.form-input,
input.form-input,
textarea.form-input,
select.form-input {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--black);
    background: var(--white);
    border: 1.5px solid var(--stone);
    border-radius: var(--radius-md);
    padding: 12px 15px;
    width: 100%;
    transition: border-color var(--dur-micro) var(--ease-out),
                box-shadow var(--dur-fast) var(--ease-out);
}
.form-input::placeholder { color: var(--ash); }
.form-input:focus {
    border-color: var(--green);
    outline: none;
    box-shadow: var(--shadow-ring);
}

/* Form labels */
.form-label,
label.form-label {
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: var(--track-wide);
    text-transform: uppercase;
    color: var(--ash);
    display: block;
    margin-bottom: 0.4rem;
}

/* Tables (admin lists) */
.admin-table,
table.admin-table,
.data-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-body);
    font-size: 0.875rem;
    background: var(--white);
    border-radius: var(--radius-lg);
    overflow: hidden;
}
.admin-table thead th,
.data-table thead th {
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: var(--track-wider);
    text-transform: uppercase;
    color: var(--ash);
    text-align: left;
    padding: 0.85rem 1rem;
    border-bottom: 1.5px solid var(--color-line);
    background: var(--white);
}
.admin-table tbody td,
.data-table tbody td {
    padding: 1rem;
    color: var(--charcoal);
    border-bottom: 1px solid var(--color-line);
    vertical-align: middle;
}
.admin-table tbody tr:hover,
.data-table tbody tr:hover { background: var(--green-tint); }
.admin-table .num,
.data-table .num,
.admin-table [data-mono],
.data-table [data-mono] {
    font-family: var(--font-mono);
    font-feature-settings: "tnum";
}

/* Status pills inside tables */
.status-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.75rem;
    border-radius: var(--radius-pill);
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: var(--track-wide);
    text-transform: uppercase;
    background: var(--green-tint);
    color: var(--green-deeper);
}
.status-pill--warn { background: rgba(184, 134, 11, 0.15); color: #8a5a00; }
.status-pill--err  { background: rgba(179, 38, 30, 0.10);  color: #8c1c16; }
.status-pill--neutral { background: var(--color-line); color: var(--charcoal); }

/* Login / auth pages */
.auth-shell {
    min-height: calc(100vh - 80px);
    display: flex; align-items: center; justify-content: center;
    padding: 3rem 1.25rem;
    background: var(--ivory);
}
.auth-card {
    width: 100%;
    max-width: 420px;
    background: var(--white);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
    box-shadow: var(--shadow-md);
}
.auth-card h1 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--black);
    margin: 0 0 0.4rem;
}
.auth-card p.auth-card__sub {
    font-family: var(--font-body);
    color: var(--ash);
    font-size: 0.95rem;
    margin: 0 0 2rem;
}

/* Error pages (404 etc.) */
.error-page {
    min-height: 80vh;
    display: flex; align-items: center; justify-content: center;
    background: var(--ivory);
    padding: 4rem 1.25rem;
}
.error-page__inner { text-align: center; max-width: 540px; }
.error-page__code {
    font-family: var(--font-mono);
    font-feature-settings: "tnum";
    font-size: 6rem;
    font-weight: 500;
    color: var(--green);
    line-height: 1;
}
.error-page__title {
    font-family: var(--font-display);
    font-size: var(--text-title);
    font-weight: 600;
    color: var(--black);
    margin: 1rem 0 0.75rem;
}
.error-page__body {
    font-family: var(--font-body);
    color: var(--ash);
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 1.75rem;
}

/* Numeric / order-ref strings */
.ref, .order-ref, code.ref, [data-ref] {
    font-family: var(--font-mono);
    font-feature-settings: "tnum";
    color: var(--charcoal);
    background: var(--green-tint);
    padding: 0.2rem 0.5rem;
    border-radius: 6px;
    font-size: 0.85em;
}

/* Filter chip / category pill rows */
.filter-row {
    display: flex; flex-wrap: wrap; gap: 0.5rem;
    margin-bottom: 2rem;
}
.filter-row .btn--outline {
    border-color: var(--color-line);
    color: var(--charcoal);
}
.filter-row .btn--outline:hover {
    background: var(--green-tint);
    color: var(--green-dark);
    border-color: var(--green);
}
.filter-row .btn--outline.active {
    background: var(--black);
    color: var(--white);
    border-color: var(--black);
}

/* Booking widget (experience-detail right rail) */
.booking-widget {
    background: var(--white);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    box-shadow: var(--shadow-sm);
    position: sticky;
    top: 100px;
}
.booking-widget h3 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--black);
    margin: 0 0 1rem;
}

/* Conservation page legacy classes (.impact-prog etc.) */
.impact-prog {
    background: var(--color-line);
    height: 6px;
    border-radius: var(--radius-pill);
    overflow: hidden;
    margin-top: 1rem;
}
.impact-prog__fill {
    background: var(--gradient-primary);
    height: 100%;
    transition: width var(--dur-slow) var(--ease-out);
}
.donation-form-shell {
    background: var(--white);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    padding: 2rem;
    box-shadow: var(--shadow-md);
}
.donation-chip-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.65rem;
    margin-bottom: 1rem;
}
.donation-chip-grid button {
    border: 1.5px solid var(--stone);
    background: var(--white);
    color: var(--black);
    border-radius: var(--radius-md);
    padding: 0.85rem 0.9rem;
    cursor: pointer;
    font-family: var(--font-mono);
    font-weight: 500;
    transition: all var(--dur-fast) var(--ease-out);
}
.donation-chip-grid button:hover {
    border-color: var(--green);
    background: var(--green-tint);
}
.donation-chip-grid button.active,
.donation-chip-grid button[aria-pressed="true"] {
    background: var(--green);
    color: var(--white);
    border-color: var(--green);
    box-shadow: var(--shadow-green);
}
.donation-note {
    padding: 0.95rem 1rem;
    border-radius: var(--radius-md);
    background: var(--green-tint);
    color: var(--green-deeper);
    font-family: var(--font-body);
    font-size: 0.875rem;
    line-height: 1.55;
}

/* Generic legacy "form-group" + form spacing */
.form-group {
    margin-bottom: 1.25rem;
    display: flex; flex-direction: column;
    gap: 0.4rem;
}

/* Admin card (legacy class used in client dashboard, etc.) */
.admin-card {
    background: var(--white);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
}
.admin-card__header {
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid var(--color-line);
}
.admin-card__header h3 {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--black);
    margin: 0;
}
.admin-card__body { padding: 1.5rem; }
.admin-grid-2 {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 1.5rem;
}
@media (max-width: 1024px) {
    .admin-grid-2 { grid-template-columns: 1fr; }
}

/* Modal-like inline forms */
.modal-form .form-row,
.form-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
    margin-bottom: 1rem;
}

/* Flash success / error banners (replace dark-theme alphas) */
[style*="rgba(46,125,50,0.15)"],
[style*="rgba(46,125,50,0.16)"],
.alert-success {
    background: var(--green-tint) !important;
    border: 1px solid var(--green-mid) !important;
    color: var(--green-deeper) !important;
    border-radius: var(--radius-md);
    padding: 0.85rem 1rem;
}
[style*="rgba(198,40,40,0.15)"],
.alert-error {
    background: rgba(179, 38, 30, 0.08) !important;
    border: 1px solid rgba(179, 38, 30, 0.25) !important;
    color: #8c1c16 !important;
    border-radius: var(--radius-md);
    padding: 0.85rem 1rem;
}

/* page-header centered variants (some templates pass inline align-center) */
.page-header.text-center,
.page-header[style*="text-align: center"] {
    text-align: center;
}
.page-header.text-center .breadcrumb,
.page-header[style*="text-align: center"] .breadcrumb {
    justify-content: center;
}

/* ═══════════════════════════════════════════════════════════════
   GOLDEN-RWANDA-GRADE COMPONENTS — premium structures
   ═══════════════════════════════════════════════════════════════ */

/* ── Search / Discovery strip (sits BELOW the cinematic hero) ── */
.discovery {
    background: var(--white);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-xl);
    padding: 1.4rem 1.6rem;
    max-width: 980px;
    margin: 3rem auto;
    position: relative;
    z-index: 5;
}
.discovery__form {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr auto;
    gap: 0.75rem;
    align-items: end;
}
@media (max-width: 900px) {
    .discovery__form { grid-template-columns: 1fr 1fr; }
    .discovery__form button { grid-column: 1 / -1; }
}
.discovery__field { display: flex; flex-direction: column; gap: 0.35rem; }
.discovery__field label {
    font-family: var(--font-ui);
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: var(--track-wider);
    text-transform: uppercase;
    color: var(--ash);
}
.discovery__field input,
.discovery__field select {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--black);
    background: transparent;
    border: 0;
    border-bottom: 1.5px solid var(--color-line);
    padding: 0.5rem 0;
    outline: none;
    transition: border-color var(--dur-fast) var(--ease-out);
}
.discovery__field input:focus,
.discovery__field select:focus { border-color: var(--green); }
.discovery__chips {
    display: flex; flex-wrap: wrap; gap: 0.5rem;
    padding-top: 1rem;
    margin-top: 1rem;
    border-top: 1px solid var(--color-line);
}
.discovery__chips a {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: var(--track-wide);
    text-transform: uppercase;
    color: var(--charcoal);
    padding: 0.45rem 0.85rem;
    background: var(--ivory);
    border-radius: var(--radius-pill);
    transition: all var(--dur-fast) var(--ease-out);
}
.discovery__chips a:hover {
    background: var(--green);
    color: var(--white);
}

/* ── Tour / Experience full card (Golden Rwanda style) ── */
.tour-card {
    background: var(--white);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform var(--dur-normal) var(--ease-out),
                box-shadow var(--dur-normal) var(--ease-out);
    display: flex; flex-direction: column;
}
.tour-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-xl);
}
.tour-card__media {
    position: relative;
    aspect-ratio: 16 / 11;
    overflow: hidden;
    background: var(--green-tint);
}
.tour-card__media img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform var(--dur-slow) var(--ease-out);
}
.tour-card:hover .tour-card__media img { transform: scale(1.06); }
.tour-card__badge-row {
    position: absolute;
    top: 1rem; left: 1rem; right: 1rem;
    display: flex; justify-content: space-between; align-items: center;
    pointer-events: none;
}
.tour-card__rating {
    background: rgba(11, 11, 11, 0.78);
    color: var(--white);
    backdrop-filter: blur(6px);
    padding: 0.4rem 0.7rem;
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
}
.tour-card__rating::before {
    content: '★';
    color: #FFC83A;
    font-family: serif;
}
.tour-card__cat {
    background: var(--white);
    color: var(--green-dark);
    font-family: var(--font-ui);
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: var(--track-wider);
    text-transform: uppercase;
    padding: 0.4rem 0.75rem;
    border-radius: var(--radius-pill);
}
.tour-card__body { padding: 1.5rem 1.6rem 1.6rem; display: flex; flex-direction: column; flex: 1; gap: 0.5rem; }
.tour-card__loc {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: var(--track-wide);
    text-transform: uppercase;
    color: var(--ash);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
}
.tour-card__loc svg { width: 12px; height: 12px; color: var(--green); }
.tour-card__title {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--black);
    line-height: 1.2;
    margin: 0.25rem 0 0.5rem;
}
.tour-card__title a { color: inherit; }
.tour-card__title a:hover { color: var(--green-dark); }
.tour-card__meta {
    display: flex; flex-wrap: wrap; gap: 0.5rem 1rem;
    font-family: var(--font-body);
    font-size: 0.78rem;
    color: var(--ash);
    margin: 0.4rem 0 0.75rem;
}
.tour-card__meta span { display: inline-flex; align-items: center; gap: 0.35rem; }
.tour-card__meta svg { width: 13px; height: 13px; color: var(--green-dark); }
.tour-card__tags { display: flex; flex-wrap: wrap; gap: 0.3rem; margin-top: auto; padding-top: 0.5rem; }
.tour-card__tags span {
    font-family: var(--font-ui);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: var(--track-wide);
    text-transform: uppercase;
    color: var(--green-deeper);
    background: var(--green-tint);
    padding: 0.3rem 0.6rem;
    border-radius: 6px;
}
.tour-card__footer {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-line);
    display: flex; align-items: center; justify-content: space-between;
}
.tour-card__price-block {
    display: flex; flex-direction: column; gap: 0.1rem;
}
.tour-card__price-from {
    font-family: var(--font-ui);
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: var(--track-wide);
    text-transform: uppercase;
    color: var(--ash);
}
.tour-card__price {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    color: var(--green);
    font-weight: 500;
}
.tour-card__price-unit {
    font-family: var(--font-body);
    font-size: 0.78rem;
    color: var(--ash);
    margin-left: 0.2rem;
}

/* ── Destinations grid (image cards) ── */
.dest-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.25rem;
}
.dest-card {
    position: relative;
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-lg);
    overflow: hidden;
    isolation: isolate;
    color: var(--white);
    display: flex;
    align-items: flex-end;
}
.dest-card img {
    position: absolute; inset: 0;
    width: 100%; height: 100%; object-fit: cover;
    z-index: -2;
    transition: transform var(--dur-slow) var(--ease-out);
}
.dest-card::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.10) 60%);
    z-index: -1;
}
.dest-card:hover img { transform: scale(1.07); }
.dest-card__body {
    padding: 1.5rem 1.4rem;
    width: 100%;
}
.dest-card__name {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--white);
    line-height: 1.1;
    margin: 0;
}
.dest-card__count {
    font-family: var(--font-ui);
    font-size: 0.68rem;
    letter-spacing: var(--track-wider);
    text-transform: uppercase;
    color: var(--green-mid);
    margin-top: 0.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-weight: 600;
}
.dest-card__count::before {
    content: '';
    width: 16px; height: 1px; background: currentColor; opacity: 0.7;
}

/* ── Activity icon-grid ── */
.activity-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
}
.activity-tile {
    background: var(--white);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    padding: 1.6rem 1.25rem;
    text-align: center;
    transition: all var(--dur-fast) var(--ease-out);
    text-decoration: none;
}
.activity-tile:hover {
    background: var(--green-tint);
    border-color: var(--green-mid);
    transform: translateY(-3px);
    color: inherit;
}
.activity-tile__icon {
    width: 56px; height: 56px;
    border-radius: 50%;
    background: var(--green-tint);
    color: var(--green-dark);
    display: inline-flex; align-items: center; justify-content: center;
    margin-bottom: 0.85rem;
}
.activity-tile:hover .activity-tile__icon {
    background: var(--green);
    color: var(--white);
}
.activity-tile__icon svg { width: 24px; height: 24px; }
.activity-tile__name {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--black);
    margin: 0 0 0.2rem;
}
.activity-tile__desc {
    font-family: var(--font-body);
    font-size: 0.78rem;
    color: var(--ash);
    margin: 0;
    line-height: 1.4;
}

/* ── Partners / affiliations strip ── */
.partner-strip {
    background: var(--white);
    border-top: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
    padding: 2.5rem 0;
}
.partner-strip__inner {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: 0 2rem;
}
.partner-strip__heading {
    text-align: center;
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: var(--track-wider);
    text-transform: uppercase;
    color: var(--ash);
    margin-bottom: 1.5rem;
}
.partner-strip__row {
    display: flex; flex-wrap: wrap; align-items: center; justify-content: center;
    gap: 2.5rem;
    opacity: 0.7;
}
.partner-strip__row .partner {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--charcoal);
    letter-spacing: 0.02em;
    transition: opacity var(--dur-fast) var(--ease-out);
}
.partner-strip__row .partner:hover { opacity: 1; }

/* ── Mega-menu navigation ── */
.has-mega { position: relative; }
.has-mega > a::after {
    content: '▾';
    margin-left: 0.3rem;
    font-size: 0.7em;
    opacity: 0.6;
}
.mega-menu {
    position: absolute;
    top: 100%; left: 50%;
    transform: translate(-50%, 8px);
    background: var(--white);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xl);
    padding: 1.75rem;
    width: 720px;
    max-width: calc(100vw - 2rem);
    display: grid;
    grid-template-columns: 1fr 1fr 280px;
    gap: 2rem;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity var(--dur-fast) var(--ease-out),
                transform var(--dur-fast) var(--ease-out),
                visibility var(--dur-fast) linear;
    z-index: var(--z-dropdown);
}
.has-mega:hover .mega-menu,
.has-mega:focus-within .mega-menu {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translate(-50%, 4px);
}
.mega-menu h4 {
    font-family: var(--font-ui);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: var(--track-wider);
    text-transform: uppercase;
    color: var(--ash);
    margin: 0 0 0.85rem;
}
.mega-menu ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
.mega-menu ul a {
    font-family: var(--font-body);
    color: var(--charcoal);
    font-size: 0.92rem;
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    padding: 0;
    background: transparent !important;
    margin: 0 !important;
}
.mega-menu ul a::after { display: none !important; }
.mega-menu ul a:hover { color: var(--green-dark); }
.mega-menu__feature {
    border-radius: var(--radius-md);
    overflow: hidden;
    aspect-ratio: 4 / 5;
    position: relative;
    background: var(--green-tint);
}
.mega-menu__feature img {
    width: 100%; height: 100%; object-fit: cover;
}
.mega-menu__feature-caption {
    position: absolute; left: 0; right: 0; bottom: 0;
    padding: 0.85rem 1rem;
    background: linear-gradient(to top, rgba(0,0,0,0.78) 0%, transparent 100%);
    color: var(--white);
}
.mega-menu__feature-caption h5 {
    font-family: var(--font-display);
    font-size: 1rem;
    margin: 0;
    color: var(--white);
}
.mega-menu__feature-caption p {
    margin: 0.1rem 0 0;
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.78rem;
}

/* ── Big section with split image (mission, conservation impact) ── */
.split-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
}
.split-section--reverse > div:first-child { order: 2; }
@media (max-width: 900px) {
    .split-section { grid-template-columns: 1fr; gap: 2rem; }
    .split-section--reverse > div:first-child { order: 0; }
}
.split-section__media {
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-xl);
    position: relative;
}
.split-section__media img {
    width: 100%; height: 100%; object-fit: cover;
}
.split-section__media-tag {
    position: absolute;
    top: 1rem; left: 1rem;
    background: var(--white);
    padding: 0.5rem 0.85rem;
    border-radius: var(--radius-pill);
    font-family: var(--font-ui);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: var(--track-wider);
    text-transform: uppercase;
    color: var(--green-dark);
}

/* ── Hero scroll indicator ── */
.scroll-indicator {
    position: absolute;
    right: 60px; bottom: 52px;
    display: flex; flex-direction: column; align-items: center;
    gap: 0.6rem;
    color: var(--white);
    font-family: var(--font-ui);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: var(--track-wider);
    text-transform: uppercase;
    opacity: 0.78;
    z-index: 6;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
}
.scroll-indicator span:first-child { transform: rotate(180deg); writing-mode: horizontal-tb; }
@media (max-width: 768px) {
    .scroll-indicator { right: 1.5rem; bottom: 2rem; writing-mode: horizontal-tb; transform: none; }
    .scroll-indicator span:first-child { transform: none; }
}
.scroll-indicator__line {
    width: 1px; height: 36px;
    background: linear-gradient(to bottom, transparent, var(--white));
    animation: pulseDown 2s ease-in-out infinite;
}
@keyframes pulseDown {
    0%, 100% { opacity: 0.4; transform: scaleY(0.8); }
    50%      { opacity: 1;   transform: scaleY(1); }
}

/* ── Big quote block ── */
.big-quote {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.5vw, 2.25rem);
    font-style: italic;
    font-weight: 400;
    line-height: 1.35;
    color: var(--black);
    max-width: 38ch;
}
.big-quote::before {
    content: '“';
    display: block;
    font-size: 4rem;
    line-height: 0.8;
    color: var(--green);
    margin-bottom: 0.5rem;
}

/* ═══════════════════════════════════════════════════════════════
   PREMIUM POLISH — notifications, messages, cart, mega-menu
   ═══════════════════════════════════════════════════════════════ */

/* ── Notifications inbox list ── */
.notif-row {
    background: var(--white);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    padding: 1.1rem 1.4rem;
    display: flex; gap: 1rem; align-items: flex-start;
    transition: border-color var(--dur-fast) var(--ease-out),
                box-shadow var(--dur-fast) var(--ease-out),
                transform var(--dur-fast) var(--ease-out);
    text-decoration: none; color: inherit;
}
.notif-row:hover {
    border-color: var(--green-mid);
    box-shadow: var(--shadow-md);
    transform: translateY(-1px);
    color: inherit;
}
.notif-row--unread {
    border-color: var(--green-mid);
    background: var(--green-tint);
}
.notif-row__icon {
    width: 40px; height: 40px;
    border-radius: 12px;
    background: var(--green-tint);
    color: var(--green-dark);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
}
.notif-row--unread .notif-row__icon {
    background: var(--green);
    color: var(--white);
}
.notif-row__icon svg { width: 18px; height: 18px; }
.notif-row__body { flex: 1; min-width: 0; }
.notif-row__head {
    display: flex; gap: 0.6rem; align-items: center; flex-wrap: wrap;
    margin-bottom: 0.2rem;
}
.notif-row__cat {
    font-family: var(--font-ui);
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: var(--track-wider);
    text-transform: uppercase;
    color: var(--green-dark);
}
.notif-row__time {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ash);
    margin-left: auto;
}
.notif-row__title {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--black);
    margin: 0 0 0.2rem;
}
.notif-row__desc {
    font-family: var(--font-body);
    color: var(--ash);
    font-size: 0.875rem;
    line-height: 1.5;
    margin: 0;
}
.notif-row--unread::after {
    content: '';
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--green);
    flex-shrink: 0; margin-top: 0.6rem;
}

/* ── Messages — conversation list ── */
.conv-row {
    background: var(--white);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    padding: 1.1rem 1.25rem;
    display: flex; gap: 1rem; align-items: flex-start;
    text-decoration: none; color: inherit;
    transition: all var(--dur-fast) var(--ease-out);
}
.conv-row:hover {
    border-color: var(--green-mid);
    box-shadow: var(--shadow-md);
    transform: translateY(-1px);
    color: inherit;
}
.conv-row__head {
    display: flex; align-items: center; gap: 0.5rem;
    margin-bottom: 0.35rem;
    flex-wrap: wrap;
}
.conv-row__time {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--ash);
}
.conv-row__subject {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--black);
    margin: 0 0 0.15rem;
}
.conv-row__preview {
    font-family: var(--font-body);
    color: var(--ash);
    font-size: 0.875rem;
    line-height: 1.5;
    margin: 0;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
}

/* ── Chip / status pill (legacy class used in inbox) ── */
.chip {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.75rem;
    border-radius: var(--radius-pill);
    font-family: var(--font-ui);
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: var(--track-wide);
    text-transform: uppercase;
    background: var(--color-line);
    color: var(--charcoal);
}
.chip--primary { background: var(--green); color: var(--white); }
.chip--info,
.chip--awaiting-staff { background: var(--green-tint); color: var(--green-deeper); }
.chip--warning,
.chip--awaiting-client { background: rgba(184, 134, 11, 0.15); color: #8a5a00; }
.chip--muted,
.chip--closed { background: var(--color-line); color: var(--charcoal); }
.chip--success { background: var(--green); color: var(--white); }
.chip--danger { background: rgba(179, 38, 30, 0.10); color: #8c1c16; }

/* ── Add-to-cart button — premium */
.atc-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 14px 22px;
    background: var(--green);
    color: var(--white);
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: var(--track-wide);
    text-transform: uppercase;
    border: 0;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-green);
    cursor: pointer;
    transition: all var(--dur-fast) var(--ease-out);
}
.atc-btn:hover {
    background: var(--green-dark);
    transform: translateY(-2px);
    box-shadow: 0 12px 36px rgba(0, 166, 81, 0.36);
}
.atc-btn:active { transform: translateY(0); }
.atc-btn svg { width: 16px; height: 16px; }
.atc-btn--secondary {
    background: transparent;
    color: var(--black);
    border: 1.5px solid var(--black);
    box-shadow: none;
}
.atc-btn--secondary:hover {
    background: var(--black);
    color: var(--white);
    box-shadow: none;
}

/* Tiny "+" icon-button for cart actions on grid cards */
.icon-btn {
    width: 36px; height: 36px;
    border-radius: 50%;
    border: 1.5px solid var(--color-line);
    background: var(--white);
    color: var(--charcoal);
    display: inline-flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: all var(--dur-fast) var(--ease-out);
}
.icon-btn:hover {
    border-color: var(--green);
    color: var(--green);
    background: var(--green-tint);
    transform: translateY(-1px);
}
.icon-btn svg { width: 16px; height: 16px; }

/* ── Bell dropdown polish (already on base.html — refining classes) ── */
#bell-dropdown {
    border: 1px solid var(--color-line) !important;
    background: var(--white) !important;
    box-shadow: var(--shadow-xl) !important;
}
#bell-dropdown strong { font-family: var(--font-display); }
#bell-dropdown .bell__item--unread { background: var(--green-tint) !important; }

/* ── Cart drawer (slide-in from right; toggled via JS) ── */
.cart-drawer {
    position: fixed;
    top: 0; right: 0; bottom: 0;
    width: 420px;
    max-width: 90vw;
    background: var(--white);
    box-shadow: var(--shadow-xl);
    z-index: var(--z-modal);
    transform: translateX(100%);
    transition: transform var(--dur-normal) var(--ease-out);
    display: flex;
    flex-direction: column;
}
.cart-drawer.is-open { transform: translateX(0); }
.cart-drawer__head {
    padding: 1.5rem;
    display: flex; align-items: center; justify-content: space-between;
    border-bottom: 1px solid var(--color-line);
}
.cart-drawer__head h3 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--black);
    margin: 0;
}
.cart-drawer__body { flex: 1; overflow-y: auto; padding: 1rem 1.5rem; }
.cart-drawer__foot { padding: 1.5rem; border-top: 1px solid var(--color-line); }
.cart-drawer__overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    z-index: calc(var(--z-modal) - 1);
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--dur-fast) var(--ease-out);
}
.cart-drawer__overlay.is-open { opacity: 1; pointer-events: auto; }

/* ═══════════════════════════════════════════════════════════════
   LUXURY UPLIFT (V3) — Singita / Aman / Belmond level
   Bigger serifs · glass nav · gold accents · generous whitespace
   These rules override earlier defaults via !important so the
   visual change is unmistakable on hard-refresh.
   ═══════════════════════════════════════════════════════════════ */

/* Hero — much larger, italic gold accent */
.hero--premium .hero__title {
    font-size: clamp(3.5rem, 9vw, 8rem) !important;
    font-weight: 400 !important;
    letter-spacing: -0.025em !important;
    line-height: 0.95 !important;
    text-shadow: 0 4px 20px rgba(0,0,0,0.40);
}
.hero--premium .hero__title .accent {
    font-style: italic !important;
    font-weight: 300 !important;
    color: #D4B26A !important;
}
.hero--premium .hero__tagline {
    font-size: 0.78rem !important;
    color: #D4B26A !important;
    letter-spacing: 0.32em !important;
    margin-bottom: 2.25rem !important;
}
.hero--premium .hero__tagline::before {
    width: 56px !important;
    background: #D4B26A !important;
}
.hero--premium .hero__desc {
    font-size: 1.25rem !important;
    line-height: 1.55 !important;
    max-width: 620px !important;
    color: rgba(255,255,255,0.95) !important;
}
.hero--premium .container {
    padding: 0 80px 80px !important;
}
@media (max-width: 768px) {
    .hero--premium .container { padding: 0 1.5rem 3rem !important; }
}

/* Section titles — bigger, more editorial */
.section-title,
h2.section-title {
    font-size: clamp(2.25rem, 4.5vw, 4rem) !important;
    font-weight: 400 !important;
    letter-spacing: -0.02em !important;
    line-height: 1.05 !important;
}
.section-subtitle {
    font-size: 1.15rem !important;
    line-height: 1.65 !important;
    font-weight: 300 !important;
    color: #5A5A5A !important;
}
.section-label,
.eyebrow {
    font-size: 0.7rem !important;
    letter-spacing: 0.32em !important;
    font-weight: 600 !important;
    color: #876A2A !important;
}
.section-label::before,
.eyebrow::before {
    width: 56px !important;
    background: #D4B26A !important;
}

/* More generous section padding */
.section {
    padding: clamp(5rem, 9vw, 9rem) 0 !important;
}

/* Glass-blur nav — much stronger */
.nav.nav--premium {
    background: rgba(249, 248, 245, 0.72) !important;
    backdrop-filter: saturate(180%) blur(22px) !important;
    -webkit-backdrop-filter: saturate(180%) blur(22px) !important;
    transition: all var(--dur-slow) var(--ease-out);
}
.nav.nav--premium.is-scrolled {
    background: rgba(255, 255, 255, 0.92) !important;
    border-bottom: 1px solid rgba(11,11,11,0.06) !important;
    box-shadow: 0 1px 0 rgba(11,11,11,0.04), 0 8px 32px rgba(11,11,11,0.04) !important;
}
.nav.nav--premium .nav__inner {
    padding: 1.15rem 60px !important;
}
@media (max-width: 768px) {
    .nav.nav--premium .nav__inner { padding: 1rem 1.5rem !important; }
}
.nav.nav--premium .nav__links a {
    font-size: 0.7rem !important;
    letter-spacing: 0.18em !important;
    color: #1C1C1C !important;
    margin: 0 0.85rem !important;
    padding: 0.6rem 0 !important;
    font-weight: 500 !important;
}
.nav.nav--premium .nav__links a::after {
    background: #D4B26A !important;
    height: 1.5px !important;
}
.nav.nav--premium .nav__links a.active,
.nav.nav--premium .nav__links a:hover {
    color: #00A651 !important;
}
.nav.nav--premium .nav__logo-text span:first-child {
    font-size: 1.1rem !important;
    font-weight: 500 !important;
    letter-spacing: 0.005em !important;
}
.nav.nav--premium .nav__logo-text span:last-child {
    color: #876A2A !important;
}

/* Cards — sharper corners, dramatic shadow on hover */
.card.card--editorial,
.card:not(.card--editorial),
.tour-card,
.dept-card {
    border-radius: 4px !important;
    border-color: rgba(11,11,11,0.06) !important;
    transition: transform 600ms cubic-bezier(0.16,1,0.3,1),
                box-shadow 600ms cubic-bezier(0.16,1,0.3,1) !important;
}
.card.card--editorial:hover,
.card:not(.card--editorial):hover,
.tour-card:hover,
.dept-card:hover {
    transform: translateY(-8px) !important;
    box-shadow: 0 32px 64px rgba(11,11,11,0.14), 0 12px 24px rgba(11,11,11,0.08) !important;
}
.card.card--editorial .card__image,
.card:not(.card--editorial) .card__image,
.tour-card__media,
.dept-card__media {
    border-radius: 4px 4px 0 0 !important;
}
.card.card--editorial .card__image img,
.card:not(.card--editorial) .card__image img,
.tour-card__media img,
.dept-card__media img {
    transition: transform 1200ms cubic-bezier(0.22,0.61,0.36,1) !important;
}
.card.card--editorial:hover .card__image img,
.card:not(.card--editorial):hover .card__image img,
.tour-card:hover .tour-card__media img,
.dept-card:hover .dept-card__media img {
    transform: scale(1.08) !important;
}

/* Card titles — more dramatic Cormorant */
.card.card--editorial .card__title,
.card:not(.card--editorial) .card__title,
.tour-card__title {
    font-size: 1.5rem !important;
    font-weight: 400 !important;
    letter-spacing: -0.01em !important;
    line-height: 1.15 !important;
}
.dept-card__title {
    font-size: 1.875rem !important;
    font-weight: 400 !important;
    letter-spacing: -0.01em !important;
    line-height: 1.1 !important;
}

/* Buttons — refined, sharp corners */
.btn--primary,
.btn--outline,
.btn--ghost,
.btn--secondary,
.btn--quiet {
    border-radius: 2px !important;
}
.btn--primary {
    font-size: 0.72rem !important;
    letter-spacing: 0.22em !important;
    padding: 16px 36px !important;
}
.btn--lg {
    padding: 20px 44px !important;
    font-size: 0.78rem !important;
}
.btn--sm {
    padding: 11px 22px !important;
    font-size: 0.66rem !important;
    letter-spacing: 0.18em !important;
}
.btn--outline {
    border-width: 1px !important;
    background: transparent !important;
    font-size: 0.72rem !important;
    letter-spacing: 0.22em !important;
    padding: 16px 36px !important;
}
.btn--with-icon svg {
    transition: transform 400ms cubic-bezier(0.16,1,0.3,1) !important;
}

/* Discovery search strip — more luxurious */
.discovery {
    border-radius: 4px !important;
    box-shadow: 0 24px 64px rgba(11,11,11,0.12), 0 8px 16px rgba(11,11,11,0.06) !important;
}

/* Footer — much darker, gold accents */
.footer {
    background: #0B0B0B !important;
    padding: 6rem 0 3rem !important;
}
.footer__heading {
    color: #D4B26A !important;
    font-size: 0.7rem !important;
    letter-spacing: 0.32em !important;
}
.footer__newsletter {
    background: linear-gradient(135deg, #00321B 0%, #00582F 50%, #00A651 100%) !important;
    border-radius: 4px !important;
}
.footer__newsletter h3 {
    font-family: var(--font-display) !important;
    font-size: 2rem !important;
    font-weight: 400 !important;
    letter-spacing: -0.01em !important;
}

/* Build-version stamp — proves the new CSS is loaded */
.footer::after {
    content: 'BUILD · v2026.05.09 · CINEMATIC';
    display: block;
    text-align: center;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(212,178,106,0.20);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.32em;
    color: #D4B26A;
}

/* Scroll indicator — gold */
.scroll-indicator { color: #D4B26A !important; opacity: 0.85 !important; }
.scroll-indicator__line { background: linear-gradient(to bottom, transparent, #D4B26A) !important; }

/* CTA strip — darker, gold ghost button */
.cta-strip {
    background: #0B0B0B !important;
    color: #fff !important;
    padding: clamp(5rem, 8vw, 7rem) 0 !important;
}
.cta-strip__title {
    font-size: clamp(2.25rem, 4vw, 3.5rem) !important;
    font-weight: 400 !important;
    letter-spacing: -0.015em !important;
    color: #fff !important;
}
.cta-strip__sub {
    font-size: 1.1rem !important;
    color: rgba(255,255,255,0.78) !important;
    line-height: 1.6 !important;
    font-weight: 300 !important;
}
.cta-strip .btn--ghost {
    border-color: #D4B26A !important;
    color: #D4B26A !important;
}
.cta-strip .btn--ghost:hover {
    background: #D4B26A !important;
    color: #0B0B0B !important;
}

/* Trust strip — quieter, more refined */
.trust-strip {
    background: var(--ivory) !important;
    border-top: 1px solid rgba(11,11,11,0.06) !important;
    border-bottom: 1px solid rgba(11,11,11,0.06) !important;
    padding: 2rem 0 !important;
}
.trust-strip__inner { padding: 0 60px !important; }
.trust-strip__item {
    font-size: 0.78rem !important;
    color: var(--charcoal) !important;
}
.trust-strip__item strong { color: #00A651 !important; }
.trust-strip__item svg { color: #D4B26A !important; }

/* Pillar — gold-tinted icon */
.pillar {
    background: var(--white) !important;
    border-radius: 4px !important;
    padding: 2.5rem 2rem !important;
    border: 1px solid rgba(11,11,11,0.06) !important;
}
.pillar__title {
    font-size: 1.625rem !important;
    font-weight: 400 !important;
    letter-spacing: -0.01em !important;
}
.pillar__icon {
    background: #FCF4DD !important;
    color: #876A2A !important;
    border-radius: 4px !important;
}

/* Departments grid — black/gold badges */
.dept-card__media { aspect-ratio: 4/5 !important; }
.dept-card__badge {
    background: #0B0B0B !important;
    color: #D4B26A !important;
    border-radius: 0 !important;
    padding: 0.4rem 0.85rem !important;
}

/* Mega-menu — more luxe */
.mega-menu {
    border-radius: 4px !important;
    box-shadow: 0 32px 80px rgba(11,11,11,0.16) !important;
    padding: 2rem !important;
}
.mega-menu h4 {
    color: #876A2A !important;
    font-size: 0.65rem !important;
    letter-spacing: 0.32em !important;
}
.mega-menu ul a:hover { color: #00A651 !important; }

/* Donation amount picker */
.donation-amounts {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(80px, 1fr));
    gap: 0.55rem;
    margin: 1.25rem 0;
}
.donation-amount {
    padding: 0.85rem 0.5rem;
    background: var(--white);
    border: 1.5px solid var(--stone);
    border-radius: var(--radius-md);
    font-family: var(--font-mono);
    font-weight: 500;
    color: var(--black);
    cursor: pointer;
    transition: all var(--dur-fast) var(--ease-out);
    text-align: center;
}
.donation-amount:hover { border-color: var(--green); background: var(--green-tint); }
.donation-amount.active {
    background: var(--green);
    color: var(--white);
    border-color: var(--green);
    box-shadow: var(--shadow-green);
}

/* ═══════════════════════════════════════════════════════════════
   PROTOTYPE-EXACT REBUILD (V4) — matches your reference design.
   Bold geometric sans throughout. No serif. No gold. Pure green.
   This block overrides everything above with !important so the
   change is unmistakable on hard-refresh.
   ═══════════════════════════════════════════════════════════════ */

@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

:root {
    --font-display: 'Plus Jakarta Sans', 'Inter', system-ui, sans-serif !important;
    --font-ui:      'Inter', system-ui, sans-serif !important;
    --font-body:    'Inter', system-ui, sans-serif !important;
    --font-heading: 'Plus Jakarta Sans', 'Inter', system-ui, sans-serif !important;
    --font-eyebrow: 'Inter', sans-serif !important;
}

body { font-family: 'Inter', system-ui, sans-serif !important; color: var(--charcoal) !important; }
h1, h2, h3, h4, h5, h6 {
    font-family: 'Plus Jakarta Sans', 'Inter', system-ui, sans-serif !important;
    font-style: normal !important;
    color: var(--black) !important;
    letter-spacing: -0.02em !important;
}

.section-label,
.eyebrow,
.hero--premium .hero__tagline {
    font-family: 'Inter', sans-serif !important;
    color: var(--green) !important;
    font-size: 0.75rem !important;
    font-weight: 700 !important;
    letter-spacing: 0.18em !important;
    text-transform: uppercase !important;
    display: inline-block !important;
}
.section-label::before,
.eyebrow::before,
.hero--premium .hero__tagline::before { display: none !important; }

/* Hero — match prototype: HUGE bold sans-serif title */
.hero--premium .hero__title {
    font-family: 'Plus Jakarta Sans', 'Inter', sans-serif !important;
    font-style: normal !important;
    font-size: clamp(4.5rem, 14vw, 14rem) !important;
    font-weight: 800 !important;
    text-transform: uppercase !important;
    letter-spacing: -0.04em !important;
    line-height: 0.85 !important;
    color: var(--white) !important;
    text-shadow: 0 4px 20px rgba(0,0,0,0.30) !important;
    max-width: none !important;
    margin: 1.5rem 0 1.75rem !important;
}
.hero--premium .hero__title .accent {
    font-style: normal !important;
    font-weight: 800 !important;
    color: var(--green) !important;
}
.hero--premium .hero__desc {
    font-family: 'Inter', sans-serif !important;
    font-size: 1.05rem !important;
    font-weight: 400 !important;
    line-height: 1.5 !important;
    color: rgba(255,255,255,0.92) !important;
    max-width: 560px !important;
}
.hero--premium .container { padding: 0 60px 70px !important; }
@media (max-width: 768px) {
    .hero--premium .container { padding: 0 1.5rem 2.5rem !important; }
    .hero--premium .hero__title { font-size: clamp(3rem, 16vw, 6rem) !important; }
}

/* Section title — bold sans, NOT serif */
.section-title, h2.section-title {
    font-family: 'Plus Jakarta Sans', sans-serif !important;
    font-style: normal !important;
    font-size: clamp(2rem, 4vw, 3.25rem) !important;
    font-weight: 800 !important;
    letter-spacing: -0.03em !important;
    line-height: 1.1 !important;
    color: var(--black) !important;
}
.section-subtitle {
    font-family: 'Inter', sans-serif !important;
    font-size: 1rem !important;
    font-weight: 400 !important;
    color: var(--ash) !important;
    line-height: 1.6 !important;
}

/* NAV — square logo block, sans menu */
.nav.nav--premium {
    background: rgba(255, 255, 255, 0.96) !important;
    backdrop-filter: saturate(180%) blur(18px) !important;
    -webkit-backdrop-filter: saturate(180%) blur(18px) !important;
}
.nav.nav--premium .nav__inner {
    padding: 1.1rem 60px !important;
    max-width: 1600px !important;
}
@media (max-width: 768px) { .nav.nav--premium .nav__inner { padding: 0.9rem 1.5rem !important; } }

.nav.nav--premium .nav__logo-image {
    width: 48px !important;
    height: 48px !important;
    border-radius: 8px !important;
    background: var(--green) !important;
    object-fit: cover !important;
    box-shadow: none !important;
}
.nav.nav--premium .nav__logo-text { line-height: 1.05 !important; }
.nav.nav--premium .nav__logo-text span:first-child {
    font-family: 'Inter', sans-serif !important;
    font-size: 0.78rem !important;
    font-weight: 800 !important;
    letter-spacing: 0.03em !important;
    text-transform: uppercase !important;
    color: var(--black) !important;
}
.nav.nav--premium .nav__logo-text span:last-child {
    font-family: 'Inter', sans-serif !important;
    font-size: 0.62rem !important;
    font-weight: 600 !important;
    letter-spacing: 0.18em !important;
    text-transform: uppercase !important;
    color: var(--ash) !important;
}

.nav.nav--premium .nav__links { gap: 1.5rem !important; }
.nav.nav--premium .nav__links a {
    font-family: 'Inter', sans-serif !important;
    font-size: 0.78rem !important;
    font-weight: 700 !important;
    letter-spacing: 0.16em !important;
    text-transform: uppercase !important;
    color: var(--charcoal) !important;
    margin: 0 !important;
    padding: 0.5rem 0 !important;
    background: transparent !important;
    border-radius: 0 !important;
}
.nav.nav--premium .nav__links a::after {
    background: var(--green) !important;
    height: 2px !important;
}
.nav.nav--premium .nav__links a.active,
.nav.nav--premium .nav__links a:hover {
    color: var(--green) !important;
    background: transparent !important;
}

.nav__cta { gap: 0.85rem !important; align-items: center !important; }
.nav__cta .btn {
    font-family: 'Inter', sans-serif !important;
    font-weight: 700 !important;
    letter-spacing: 0.14em !important;
    text-transform: uppercase !important;
    border-radius: 0 !important;
    border: 0 !important;
    background: transparent !important;
    color: var(--black) !important;
    padding: 0.5rem 0 !important;
    box-shadow: none !important;
    font-size: 0.72rem !important;
}
.nav__cta .btn:hover { background: transparent !important; color: var(--green) !important; transform: none !important; }
.nav__cta .btn--primary {
    background: var(--green) !important;
    color: var(--white) !important;
    padding: 0.7rem 1.4rem !important;
    border-radius: 6px !important;
}
.nav__cta .btn--primary:hover { background: var(--green-dark) !important; color: var(--white) !important; }

/* Round nav-icon (messages, bell, bag) */
.nav-icon {
    position: relative;
    width: 40px; height: 40px;
    display: inline-flex; align-items: center; justify-content: center;
    background: transparent;
    color: var(--black);
    border: 0;
    cursor: pointer;
    transition: color 200ms ease;
    text-decoration: none;
}
.nav-icon:hover { color: var(--green); }
.nav-icon svg { width: 22px; height: 22px; }
.nav-icon__dot {
    position: absolute; top: 7px; right: 7px;
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #E53935;
    border: 2px solid var(--white);
}

/* Stats band — BLACK background, GREEN numbers */
.kpi-strip,
.stats-band {
    background: var(--black) !important;
    color: var(--white) !important;
    padding: 2.5rem 0 !important;
}
.kpi-strip__inner,
.stats-band__inner {
    display: grid !important;
    grid-template-columns: repeat(4, 1fr) !important;
    gap: 0 !important;
    max-width: 1600px !important;
    margin: 0 auto !important;
    padding: 0 60px !important;
}
.kpi-strip .kpi,
.stats-band .stat {
    text-align: left;
    padding: 0.5rem 2rem;
    border-left: 1px solid rgba(255,255,255,0.10);
    display: flex; flex-direction: column; gap: 0.4rem;
}
.kpi-strip .kpi:first-child,
.stats-band .stat:first-child { border-left: 0; padding-left: 0; }
.kpi-strip .kpi__value,
.stats-band .stat__value {
    font-family: 'Plus Jakarta Sans', sans-serif !important;
    font-size: clamp(2rem, 4vw, 3.25rem) !important;
    font-weight: 800 !important;
    color: var(--green) !important;
    letter-spacing: -0.03em !important;
    line-height: 1 !important;
    display: inline-flex; align-items: center; gap: 0.4rem;
}
.kpi-strip .kpi__label,
.stats-band .stat__label {
    font-family: 'Inter', sans-serif !important;
    font-size: 0.7rem !important;
    font-weight: 600 !important;
    letter-spacing: 0.18em !important;
    text-transform: uppercase !important;
    color: rgba(255,255,255,0.55) !important;
}
@media (max-width: 768px) {
    .kpi-strip__inner, .stats-band__inner { grid-template-columns: repeat(2, 1fr); gap: 1.5rem 0; padding: 0 1.5rem; }
}

/* Buttons — modern sans, sharper */
.btn {
    font-family: 'Inter', sans-serif !important;
    font-weight: 700 !important;
    letter-spacing: 0.14em !important;
    text-transform: uppercase !important;
    border-radius: 6px !important;
}
.btn--primary {
    background: var(--green) !important;
    color: var(--white) !important;
    padding: 14px 28px !important;
    font-size: 0.78rem !important;
    box-shadow: 0 4px 16px rgba(0,166,81,0.20) !important;
    border: 0 !important;
}
.btn--primary:hover {
    background: var(--green-dark) !important;
    box-shadow: 0 8px 24px rgba(0,166,81,0.32) !important;
    transform: translateY(-1px) !important;
}
.btn--outline {
    background: transparent !important;
    color: var(--white) !important;
    border: 1.5px solid rgba(255,255,255,0.4) !important;
    padding: 14px 28px !important;
    font-size: 0.78rem !important;
}
.btn--outline:hover {
    background: var(--white) !important;
    color: var(--black) !important;
    border-color: var(--white) !important;
}
.btn--lg { padding: 18px 36px !important; font-size: 0.85rem !important; }
.btn--sm { padding: 9px 18px !important; font-size: 0.7rem !important; letter-spacing: 0.12em !important; }
.btn--ghost {
    background: transparent !important;
    border: 1.5px solid rgba(255,255,255,0.4) !important;
    color: var(--white) !important;
}
.btn--ghost:hover { background: var(--white) !important; color: var(--black) !important; }

/* Discovery widget — pill cards in a row */
.discovery {
    background: var(--white) !important;
    border-radius: 16px !important;
    border: 1px solid rgba(11,11,11,0.06) !important;
    box-shadow: 0 12px 40px rgba(11,11,11,0.08) !important;
    padding: 0.5rem !important;
    max-width: 1100px !important;
    margin: 3rem auto !important;
}
.discovery__form {
    display: grid !important;
    grid-template-columns: 1fr 1fr 1fr auto !important;
    gap: 0 !important;
    align-items: stretch !important;
}
.discovery__field {
    padding: 0.85rem 1.5rem !important;
    border-right: 1px solid rgba(11,11,11,0.08);
    gap: 0.15rem !important;
}
.discovery__field:last-of-type { border-right: 0; }
.discovery__field label {
    font-family: 'Inter', sans-serif !important;
    font-size: 0.65rem !important;
    font-weight: 700 !important;
    letter-spacing: 0.16em !important;
    text-transform: uppercase !important;
    color: var(--black) !important;
}
.discovery__field input,
.discovery__field select {
    border: 0 !important;
    padding: 0 !important;
    font-size: 0.92rem !important;
    color: var(--ash) !important;
    background: transparent !important;
}
.discovery__form button { margin: 0.5rem !important; border-radius: 10px !important; }

/* Tour card — match prototype: tag pill + duration + title + loc + stars + green price */
.tour-card {
    background: var(--white) !important;
    border-radius: 12px !important;
    border: 1px solid rgba(11,11,11,0.06) !important;
    overflow: hidden !important;
    transition: transform 400ms ease, box-shadow 400ms ease !important;
}
.tour-card:hover {
    transform: translateY(-4px) !important;
    box-shadow: 0 24px 48px rgba(11,11,11,0.12) !important;
}
.tour-card__media {
    position: relative !important;
    aspect-ratio: 4 / 3 !important;
    background: var(--green-tint) !important;
    border-radius: 12px 12px 0 0 !important;
    overflow: hidden !important;
}
.tour-card__media img { width: 100%; height: 100%; object-fit: cover; }
.tour-card__badge-row {
    position: absolute !important;
    top: 0.85rem !important; left: 0.85rem !important; right: 0.85rem !important;
    display: flex !important; justify-content: space-between !important; align-items: center !important;
}
.tour-card__cat {
    background: var(--green) !important;
    color: var(--white) !important;
    font-family: 'Inter', sans-serif !important;
    font-size: 0.62rem !important;
    font-weight: 700 !important;
    letter-spacing: 0.14em !important;
    text-transform: uppercase !important;
    padding: 0.4rem 0.8rem !important;
    border-radius: 6px !important;
}
.tour-card__rating {
    background: var(--white) !important;
    color: var(--charcoal) !important;
    font-family: 'Inter', sans-serif !important;
    font-size: 0.72rem !important;
    font-weight: 700 !important;
    letter-spacing: 0 !important;
    padding: 0.4rem 0.7rem !important;
    border-radius: 6px !important;
    backdrop-filter: none !important;
}
.tour-card__rating::before { content: '' !important; display: none !important; }
.tour-card__body {
    padding: 1.25rem 1.4rem 1.5rem !important;
    display: flex; flex-direction: column; gap: 0.5rem;
}
.tour-card__title {
    font-family: 'Plus Jakarta Sans', sans-serif !important;
    font-size: 1.15rem !important;
    font-weight: 800 !important;
    color: var(--black) !important;
    letter-spacing: -0.02em !important;
    line-height: 1.25 !important;
    margin: 0 !important;
}
.tour-card__loc {
    font-family: 'Inter', sans-serif !important;
    font-size: 0.78rem !important;
    font-weight: 500 !important;
    color: var(--ash) !important;
    text-transform: none !important;
    letter-spacing: 0 !important;
    display: inline-flex; align-items: center; gap: 0.35rem;
}
.tour-card__loc svg { width: 14px; height: 14px; color: var(--green); }
.tour-card__stars {
    display: flex; align-items: center; gap: 0.35rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
    color: var(--ash);
}
.tour-card__stars svg { width: 13px; height: 13px; color: var(--green); fill: var(--green); }
.tour-card__price-block {
    margin-top: 0.4rem;
    display: flex; align-items: baseline; gap: 0.3rem;
}
.tour-card__price {
    font-family: 'Plus Jakarta Sans', sans-serif !important;
    font-size: 1.45rem !important;
    font-weight: 800 !important;
    color: var(--green) !important;
    letter-spacing: -0.02em !important;
}
.tour-card__price-unit {
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
    color: var(--ash);
    font-weight: 500;
}
.tour-card__footer { display: none !important; }

/* Why-Choose-Us check list */
.check-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 0.85rem 1.5rem;
    margin: 1.5rem 0;
}
.check-list__item {
    display: flex; align-items: center; gap: 0.7rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    color: var(--charcoal);
    font-weight: 500;
}
.check-list__item::before {
    content: '';
    width: 22px; height: 22px;
    border-radius: 50%;
    background: var(--green-tint);
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%2300A651' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'><polyline points='20 6 9 17 4 12'/></svg>");
    background-size: 14px 14px;
    background-position: center;
    background-repeat: no-repeat;
    flex-shrink: 0;
}

/* Rating badge (4.9/5 with stars) */
.rating-badge {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    background: var(--white);
    border: 1px solid rgba(11,11,11,0.08);
    border-radius: 12px;
    padding: 0.85rem 1.25rem;
    box-shadow: 0 8px 24px rgba(11,11,11,0.06);
}
.rating-badge__stars { display: flex; gap: 2px; color: var(--green); margin-bottom: 0.2rem; }
.rating-badge__stars svg { width: 14px; height: 14px; fill: var(--green); }
.rating-badge__score {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.65rem;
    font-weight: 800;
    color: var(--black);
    letter-spacing: -0.02em;
    line-height: 1;
}
.rating-badge__count {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    color: var(--ash);
    margin-top: 0.15rem;
}

/* Pillars / dept-cards typography reset (no serif) */
.pillar__title,
.dept-card__title {
    font-family: 'Plus Jakarta Sans', sans-serif !important;
    font-style: normal !important;
    font-weight: 800 !important;
}

/* Footer — clean black */
.footer { background: var(--black) !important; padding: 4rem 0 2rem !important; }
.footer__heading {
    font-family: 'Inter', sans-serif !important;
    color: rgba(255,255,255,0.55) !important;
    font-size: 0.7rem !important;
    font-weight: 700 !important;
    letter-spacing: 0.18em !important;
}
.footer__newsletter h3 { font-family: 'Plus Jakarta Sans', sans-serif !important; font-weight: 800 !important; }
.footer::after { display: none !important; }

/* Card prices — green sans */
.card__price,
[class*="__price"]:not([class*="-meta"]) {
    font-family: 'Plus Jakarta Sans', sans-serif !important;
    font-weight: 800 !important;
    color: var(--green) !important;
    font-size: 1.3rem !important;
    letter-spacing: -0.02em !important;
}

/* Build-version stamp — bottom-right corner badge so user can confirm CSS load */
body::after {
    content: 'V4 · PROTOTYPE-MATCH';
    position: fixed;
    bottom: 1rem; right: 1rem;
    z-index: 9999;
    background: var(--green);
    color: var(--white);
    font-family: 'Inter', sans-serif;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    padding: 0.4rem 0.75rem;
    border-radius: 4px;
    pointer-events: none;
    opacity: 0.85;
    box-shadow: 0 4px 12px rgba(0,166,81,0.3);
}

